               <div id="poster-followers" style="display: none;"><%= post.followers ? post.followers : 553 %></div>
               <div id="poster-following" style="display: none;"><%= post.following ? post.following : 234 %></div>
               <div id="poster-posts-length" style="display: none;"><%= post.postsLength ? post.postsLength : 3000 %></div> -->

              <img src="/uploads/brunoKiss-1780154542001.jpeg" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />

              <div style="flex:1; position: relative;">
                
                        <div style="font-size: 13px; font-weight: 600; color: rgba(237,232,224,.85);">
                                 <%= post.userName %> 
                                 <span style="color: rgba(237,232,224,.42);"> . 51m</span>
                        </div>

                        <h2 style="font-size: 12px; color: rgba(237,232,224,.32);" >Replying to <span style="color: #C04848;">@Gianluigi</span></h2>

                        <div class="follow-btn" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: grid; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; border: 1px solid #C04848; background-color: #C04848;">
                           <h4 style="color: #050508; font-size: .75rem;">Follow</h4>
                        </div>
                             
                  </div>
                        
              </div>
              <div class="reply-info-wrapper" style="padding: 5px 0 10px 50px;">

                  <p style="font-size: 15px;line-height:1.68;color:rgba(237,232,224,.8);margin-bottom:12px; white-space: pre-wrap;"><%= post.post %></p>

                   <% if (post.images.length !== 0) { %>

                     <article class="post-article" style="width: 100%; height: 350px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: flex; background: transparent; scroll-snap-type: inline mandatory;">

                            
                          
                            <% post.images.map((image) => { %>
        
                              <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: 98%; height: 100%; object-fit: cover; object-position: center; border-radius: inherit; scroll-snap-align: start;" />
        
                            <% }) %>
         
                          </article>

                   <% } else { %>

                    <article class="post-article" style="width: 100%; height: 350px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: none; background: transparent;">

                            
                          
                            <% post.images.map((image) => { %>
        
                              <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: calc(50% - 1px); height: 100%; object-fit: cover; object-position: center;" />
        
                            <% }) %>
         
                          </article>

                   <% } %> 

                   
                   
                  
                    <div style="display:flex; align-items:center; justify-content: space-between; gap:15px; padding: 5px 0;">
                     
                     <div class="likes-cont" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="heart-outline" style="font-size: 15px; font-weight: bold; color: #C04848;"></ion-icon>
                         <span style="font-size: 12px; color: #C04848; font-weight: 600; margin-left: 3px;"> 20</span>
                     </div>   
                     <div class="interactions" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="barcode-outline" style="font-size: 15px; font-weight: bold; color: #C04848;"></ion-icon>
                         <span style="font-size: 12px; color: #C04848; font-weight: 600; margin-left: 3px;"> 204</span>
                     </div>   
                     <ion-icon name="share-social-outline" style="font-size: 15px; font-weight: bold; color: #C04848;"></ion-icon>
                     <ion-icon name="flag-outline" style="font-size: 15px; font-weight: bold; color: #C04848;"></ion-icon>
                   
                   </div>

                  
              </div>

        </div>
        <div class="reply-card" style="padding: 16px;">

            <div class="info-button" style="display: flex; align-items: center; gap:9px; margin-bottom:13px;">

              <!-- ! element Placeholders for profile image and user info -->
               <!-- <div id="poster-username" style="display: none;"><%= post.userName %></div>
               <div id="poster-followers" style="display: none;"><%= post.followers ? post.followers : 553 %></div>
               <div id="poster-following" style="display: none;"><%= post.following ? post.following : 234 %></div>
               <div id="poster-posts-length" style="display: none;"><%= post.postsLength ? post.postsLength : 3000 %></div> -->

              <img src="/uploads/Elon-1780244334063.png" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />

              <div style="flex:1; position: relative;">
                
                        <div style="font-size: 13px; font-weight: 600; color: rgba(237,232,224,.85);">
                                 <%= post.userName %> 
                                 <span style="color: rgba(237,232,224,.42);"> . 2h</span>
                        </div>

                        <h2 style="font-size: 12px; color: rgba(237,232,224,.32);" >Replying to <span style="color: #C04848;">@Alvin</span></h2>

                        <div class="follow-btn" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: grid; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; border: 1px solid #C04848; background-color: transparent;">
                           <h4 style="color: #C04848; font-size: .75rem;">Following</h4>
                        </div>
                             
                  </div>
                        
              </div>
              <div class="reply-info-wrapper" style="padding: 5px 0 10px 50px;">

                  <p style="font-size: 15px;line-height:1.68;color:rgba(237,232,224,.8);margin-bottom:12px; white-space: pre-wrap;"><%= post.post %></p>

                  
                   <div style="display:flex; align-items:center; justify-content: space-between; gap:15px; padding: 5px 0;">
                     
                     <div class="likes-cont" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="heart-outline" style="font-size: 15px; font-weight: bold; color: #C04848;"></ion-icon>
                         <span style="font-size: 12px; color: #C04848; font-weight: 600; margin-left: 3px;"> 20</span>
                     </div>   
                     <div class="interactions" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="barcode-outline" style="font-size: 15px; font-weight: bold; color: #C04848;"></ion-icon>
                         <span style="font-size: 12px; color: #C04848; font-weight: 600; margin-left: 3px;"> 204</span>
                     </div>   
                     <ion-icon name="share-social-outline" style="font-size: 16px; font-weight: bold; color: #C04848;"></ion-icon>
                     <ion-icon name="flag-outline" style="font-size: 16px; font-weight: bold; color: #C04848;"></ion-icon>
                   
                   </div>

                  
              </div>

        </div>
       
       

    </main>
        <!--TODO ////// SHARE REPLY CONTAINER ////  -->
      <div class="sharePost" style="display: block; position: absolute; bottom: 0; left: 0; right: 0; z-index: 5; padding: 10px 14px; background: linear-gradient(to top,rgba(5,5,8,.96) 50%,transparent);">
         
      <button id="share-link" class="tap" style="width: 100%; padding: 15px 10px; border-radius: 14px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08); display: flex; align-items: center; gap:10px;">
          <!-- ! RENDERED IN JAVASCRIPT -->
      </button>

    </div>
    
    <!-- TODO ///////  VIEW POST REPLY /////// -->

    <div class="view" id="view-to-post" style="display: none; background:rgba(5,5,8,.92)">

      <div style="padding: 13px 16px;border-bottom:1px solid rgba(255,255,255,.05); display: flex; align-items:center; gap:10px; flex-shrink:0">

          <button onclick="back()" class="back" style="padding: 7px 14px; border-radius: 10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);font-size:12px;color:rgba(237,232,224,.6)">
            ✕ Cancel
          </button>
          <div class="fd" style="flex:1;font-size:16px;font-weight:700;color:rgba(237,232,224,.8)">
            Reply
          </div>
      
          <form id="post-form" action="/post" method="post">
            <input id="userid" name="userid" value="<%= user._id %>" type="text" style="display: none;">
            <input id="userrealm" name="userrealm" value="<%= user.userRealm %>" type="text" style="display: none;">
            <input id="post-input-elem" name="poststring" type="text" style="display: none;">
            <input id="post-image-input" name="imagesrc" type="text" style="display: none;" value="none" />
             
          <button type="submit" id="post-submit-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> class="tap" style="display: block; padding: 8px 20px;border-radius:12px;font-size:12px;font-weight:600;background: <%= user.userColor %>18;border: 1px solid <%= user.userColor %>52;color: <%= user.userColor %>;">Share</button>
          </form>
      </div>
      <div style="height: 78%; padding: 18px 16px; flex:1; display:flex; flex-flow: column nowrap; gap: 14px;">
        
              <div style="height: 8%; padding: 10px; display: flex; align-items: center; gap:10px;">
                 <div>
                    <div style="font-size:15px;font-weight:600;color:rgba(237,232,224,.8)">
                       <%= user.userName %>
                    </div>
                    <div style="font-size:12px;color:#C04848;">
                      Replying to @<%= user.userName %>
                    </div>
                 </div>
              </div>
      
              <div class="post-box" style="height: 88%; display: flex; flex-flow: column nowrap; overflow-x: hidden; overflow-y: scroll;">
 
                  <textarea id="post-body" placeholder="Add Caption..." maxlength="500" style="padding: 16px; border-radius: 18px 18px 0 0; font-size: 15px; line-height: 1.72; color:rgba(237,232,224,.82); background:rgba(255,255,255,.02); border: 2px solid rgba(255,255,255,.07); flex-grow: 1;"></textarea>
                
                   <!--! ///// IMAGE TO BE RENDERED IN JS AFTER MULTER UPLOAD ////  -->
                  <article id="image-article" style="width: clamp(350px, 100%, 600px); height: 60%; border-radius: 0 0 18px 18px; display: none;">

                  </article>

        
              </div>   

              <div style="text-align:right;font-size:10px;color:rgba(237,232,224,.2)">🔒 Stays within The <%= user.userRealm %></div>
      </div>
  </div>
    
    





<script >


const shareAvatarCont = document.querySelector('#share-link')


 shareAvatarCont.innerHTML = `<img src="/uploads/mwatiJS-1780147920696.jpeg" width="32" height="32" style="border-radius: 50%;"/>
