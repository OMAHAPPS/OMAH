<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

    <title>Post</title>
    <style>
/* ── FOUNDATION ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{position: relative; height:100%;overflow:hidden;background:#050508;color:#ede8e0;font-family:'Plus Jakarta Sans',sans-serif;-webkit-font-smoothing:antialiased}
#app{height:100%;position:relative;overflow:hidden}
canvas{position:fixed;inset:0;z-index:0;pointer-events:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,textarea{font-family:inherit;border:none;outline:none;background:none;color:inherit}
::-webkit-scrollbar{width:0;height:0}

/* ── TYPE ── */
.fd{font-family:'Playfair Display',serif}
.fs{font-family:'DM Serif Display',serif}

/* ── LAYOUT ── */
.view{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;overflow:hidden;animation:viewIn .42s cubic-bezier(.22,.61,.36,1) both}
.scroll{overflow-y:auto;-webkit-overflow-scrolling:touch}
.glass{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}

/* ── INTERACTIONS ── */
.tap{cursor:pointer;transition:transform .12s ease,opacity .12s ease;user-select:none;-webkit-user-select:none}
.tap:active{transform:scale(.91)!important;opacity:.72!important}

/* ── ANIMATIONS ── */
@keyframes viewIn      {from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes emerge      {from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn      {from{opacity:0}to{opacity:1}}
@keyframes orbIn       {from{opacity:0;transform:scale(.55)}to{opacity:1;transform:scale(1)}}
@keyframes msgPop      {from{opacity:0;transform:translateY(6px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes throb       {0%,100%{opacity:.42}50%{opacity:1}}
@keyframes drift       {0%,100%{transform:translateY(0) rotate(0deg)}40%{transform:translateY(-10px) rotate(.6deg)}75%{transform:translateY(4px) rotate(-.3deg)}}
@keyframes speak       {0%,100%{transform:scale(1.03)}50%{transform:scale(1.15)}}
@keyframes xpFill      {from{width:0%}}
@keyframes dotBlink    {0%,80%,100%{transform:scale(0);opacity:.4}40%{transform:scale(1);opacity:1}}
@keyframes effBurst    {0%{transform:scale(1);opacity:1}60%{transform:scale(1.6);opacity:.5}100%{transform:scale(2.4);opacity:0}}
@keyframes storyPulse  {0%,100%{box-shadow:0 0 0 0 var(--sc)}50%{box-shadow:0 0 0 4px var(--sc)}}
@keyframes heartbeat   {0%,100%{transform:scale(1)}14%{transform:scale(1.1)}28%{transform:scale(1)}42%{transform:scale(1.06)}}
@keyframes shimmer     {0%{background-position:-200% center}100%{background-position:200% center}}
</style>
</head>
<body>

  <p class="fs" id="error-display" style="position: absolute; top: 5%; left: 50%; transform: translateX(-50%); max-width: 100%; background-color: white; color:red; padding-inline: 5px; white-space: nowrap; border-radius: 2px; font-weight: bold; z-index: 100;"></p>
    
    

    <header style="position: relative; height: 10%; display: flex; align-items: center; gap: 12px; padding: 18px 16px; border-bottom: 1px solid rgba(255,255,255,.08);">
        
       <% if (query !== undefined) { %>

        <a href="/user/<%= query %>" style="font-size: 30px; font-weight: 700; color: rgba(237,232,224,.85); display: flex; align-items: center; gap:6px">
            <ion-icon name="arrow-back-outline"></ion-icon>
        </a>
        
        <% } else { %>

          <a href="/home" style="font-size: 30px; font-weight: 700; color: rgba(237,232,224,.85); display: flex; align-items: center; gap:6px">
              <ion-icon name="arrow-back-outline"></ion-icon>
          </a>

       <% } %>


        <h2 style="font-size: 20px; font-weight: 600; color: rgba(237,232,224,.85);">Post</h2>
        
    </header>
    <main style="height: 80%; width: 100%; overflow-y: scroll; overflow-x: hidden;">

        <div class="glass-images" style="margin-top: 10px; padding: 16px; border-bottom: 0.05px solid gray;"> 

            <div class="poster-info" style="text-decoration: none; display: flex; align-items: center; justify-content: space-between; gap:9px; margin-bottom:13px;">

              <!-- ! element Placeholders for profile image and user info -->
               <div id="poster-username" style="display: none;"><%= poster.userName %></div>
               <div id="poster-followers" style="display: none;"><%= poster.totalFollowers %></div>
               <div id="poster-following" style="display: none;"><%= poster.totalFollowing %></div>
               <div id="poster-posts-length" style="display: none;"><%= poster.totalPosts %></div>
               <div id="poster-id" style="display: none;"><%= poster._id %></div>
               <div id="poster-userHandle" style="display: none;">@<%= poster.userHandle !== 'none' ? poster.userHandle : poster.userName %></div>

               
              <% if (poster.userDP !== 'none') { %>

                <img src="<%= R2BASE %>/<%= poster.userDP %>" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />
                
                <% } else { %>

                  <img src="/placeholder.jpg" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />

              <% } %>
               
              <div id="post-id" style="display: none;"><%= post._id %></div>
              
              <div style="flex:1; position: relative;">
                
                        <div style="font-size: 13px; font-weight: 600; color: rgba(237,232,224,.9)">
                                 <%= post.userName %> 
                                 <% if (post.userName == user.userName) { %>
                                   <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size:9px;color: <%= user.userColor %>; background: <%= user.userColor %>1a; padding: 1px 7px; border-radius: 8px; margin-left: 5px;">you</span>
                                   <% } else { %>
                                     <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; font-size:9px;color: <%= user.userColor %>; background: <%= user.userColor %>1a; padding: 1px 7px; border-radius: 8px; margin-left: 5px;">you</span>
                                 <% } %>
                        </div>

                        <h2 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 12px; color: <%= user.userColor %>;" >@<%= post.userHandle !== 'none' ? post.userHandle : poster.userHandle !== 'none' ? poster.userHandle : poster.userName %></h2>

                        <div id="follow-btn" class="follow-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %>  style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); display: grid; place-content: center; width: fit-content; background-color: transparent;">
                          <ion-icon name="ellipsis-vertical-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; color: <%= user.userColor %>;"></ion-icon>
                        </div>
                             
              </div>
                        
            </div>

 
              <p style="font-size: 16px;line-height:1.68;color:rgba(237,232,224,.85);margin-bottom:12px; white-space: pre-wrap;"><%= post.post %></p>

                     <% if (post.images.length !== 0) { %>

                     <article class="post-article" style="width: 100%; height: 400px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: flex; align-items: center; justify-content: flex-start; background: transparent; scroll-snap-type: inline mandatory;">

                            
                          
                            <% post.images.map((image) => { %>
        
                              <img  src="<%= R2BASE %>/<%= image %>" alt="N" style="margin-inline: 3px; width: auto; height: 100%; object-fit: contain; border-radius: inherit; scroll-snap-align: start; margin-right: 5px;" />
        
                            <% }) %>
         
                          </article>

                   <% } else if (post.videoUrl !== 'none' ) { %> 

                         <video id="player" controls preload="none" style="display: block; width: 100%; height: auto; border-radius: 12px; margin-top: 13px; background-color: transparent !important; -webkit-tap-highlight-color: transparent;"
                           src="<%=R2BASE %>/<%= post.videoUrl %>"  data-src="/uploads/Expressions.mp4">
                                  Your browser does not support the video tag. 
                         </video>
                    
                   <% } else { %>

                    <article class="post-article" style="width: 100%; height: 350px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: none; background: transparent;">
                    </article>
                    <video id="player" controls preload="none" style="display: none; width: 100%; height: auto; border-radius: 12px; margin-top: 13px; background-color: transparent !important; -webkit-tap-highlight-color: transparent;"
                           src=""  data-src="">
                        Your browser does not support the video tag. 
                    </video>

                   <% } %>

                 
                   <% const postTimeStamp = post.createdAt %>
                   <% const date = new Date(postTimeStamp)  %>
                   <% const year = date.getFullYear() %>
                   <% const month = date.getMonth() + 1 < 10 ? `0${date.getMonth() + 1}` : date.getMonth() + 1 %>
                   <% const day = date.getDate() < 10 ? `0${date.getDate()}` : date.getDate() %>
                   <% const hours = date.getHours() < 10 ? `0${date.getHours()}` : date.getHours() %>
                   <% const minutes = date.getMinutes() < 10 ? `0${date.getMinutes()}` : date.getMinutes() %>


              <div style="display:flex;align-items:center;gap:15px;border-top:1px solid rgba(255,255,255,.05);padding-top:10px">

                   <h2 style="font-size: 15px;color: rgba(237,232,224,.5); display: flex; align-items: center; gap: 4px; font-weight: 400; justify-content: center;"><%= hours %>:<%= minutes %> <span>.</span> <%= day %><span id="month"></span><%= year %> <span>.</span> <span style="font-weight: bold; color: rgba(245, 245, 245, 0.8); margin-left: 5px;"><%= post.likes %></span> Likes</h2>
                   
              </div>

               <div style="display:flex; align-items:center; justify-content: space-around; gap:15px; padding: 20px 0 5px 0;">
                   
                   <ion-icon name="chatbubble-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                   <ion-icon name="heart-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                   <ion-icon name="share-social-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                   <ion-icon name="flag-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                   
              </div>
        </div>
        <div class="reply-header" style="display: flex; align-items: center; justify-content: flex-start; height: 20px; padding: 15px; margin-block: 5px;">
            
            <h2 style="color: rgba(237,232,224,.5); font-size: 15px; font-weight: 400;">Top Replies </h2>
                <span style="margin-left: 5px;"><ion-icon name="chevron-down-outline" style="font-size: 15px; color: rgba(237,232,224,.5); margin-top: 10px;"></ion-icon></span> 

        </div>


        <% replies.map((reply) => { %>

          <div class="reply-card-with-file" style="padding: 16px;">
  
              <div class="info-button" style="display: flex; align-items: center; gap:9px; margin-bottom:13px;">
  
                <!-- ! element Placeholders for profile image and user info -->
                 <div id="poster-username" style="display: none;"><%= reply.author.userName %></div>
                 <div id="poster-followers" style="display: none;"><%= reply.author.totalFollowers %></div>
                 <div id="poster-following" style="display: none;"><%= reply.author.totalFollowing %></div>
                 <div id="poster-posts-length" style="display: none;"><%= reply.author.totalPosts %></div>
                 <div id="poster-userHandle" style="display: none;">@<%= reply.author.userHandle == 'none' ? reply.author.userName : reply.author.userHandle %></div>
  
                 <% if (reply.author.userDP !== 'none') { %>
                   <img src="<%= R2BASE %>/<%= reply.author.userDP %>" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />
               <% } else { %>
                <img src="/placeholder.jpg" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />
               <% } %> 

               <div id="poster-userId" style="display: none;"><%= reply.author.userId %></div>
               <div id="post-id" style="display: none;"><%= post._id %></div>
  
                <div class="poster-info" style="text-decoration: none; flex:1; position: relative;">

                         <% const timestamp = reply.createdAt %>
                              <% const diff = new Date() - new Date(timestamp) %>
                              <% const daysPast = Math.floor( (diff / 86400000) ) %>
                              <% const hoursPast = Math.floor( (diff / 3600000) ) %>
                              <% const minutesPast = Math.floor( (diff / 60000) ) %>

                          <div style="font-size: 13px; font-weight: 600; color: rgba(237,232,224,.85);">
                                   <%= reply.author.userName %> 
                                   <% if (daysPast > 0) { %>
                               <span style="color: rgba(237, 232, 224, .42);"> . <%= daysPast %>d</span>
                               <% } else if (hoursPast > 0) { %>
                               <span style="color: rgba(237, 232, 224, .42);"> . <%= hoursPast %>h</span>
                                 <% } else if (minutesPast > 0) { %>
                                   <span style="color: rgba(237, 232, 224, .42);"> . <%= minutesPast %>m</span>
                                   <% } else if (minutesPast == 0) { %>
                                  <span style="color: rgba(237, 232, 224, .42);"> . Just Now</span>
                                  <% } %>
                          </div>
  
                          <h2 style="font-size: 12px; color: rgba(237,232,224,.32); width: 65%; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;" >Replying to <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="color: <%= user.userColor %>;">@<%= poster.userHandle !== 'none' ? poster.userHandle : poster.userName %></span></h2>
  
                          <div  class="follow-reply-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: grid; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; border: 1px solid <%= user.userColor %>; background-color: <%= user.userColor %>;">
                             <h4 style="color: #050508; font-size: .75rem;">Follow</h4>
                          </div>
                               
                </div>
                          
                </div>

                <div class="reply-info-wrapper" style="padding: 5px 0 10px 50px;">
  
                    <p style="font-size: 15px;line-height:1.68;color:rgba(237,232,224,.8);margin-bottom:12px; white-space: pre-wrap;"><%= reply.reply %></p>

                    <% if (reply.images.length !== 0) { %>


                        <% if (reply.images.length === 1) { %>
                      
                          <article class="post-article" style="width: 100%; height: auto; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: flex; background: transparent; scroll-snap-type: inline mandatory;">
     
                                      
                                 <% reply.images.map((image) => { %>
             
                                   <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: 100%; height: auto; object-fit: contain; border-radius: inherit; scroll-snap-align: start; margin-right: 5px;" />
             
                                 <% }) %>
              
                          </article>

                        <% } else { %>

                          <article class="post-article" style="width: 100%; height: 300px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: flex; background: transparent; scroll-snap-type: inline mandatory;">
     
                                      
                                 <% reply.images.map((image) => { %>
             
                                   <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: auto; height: 100%; object-fit: contain; border-radius: inherit; scroll-snap-align: start; margin-right: 5px;" />
             
                                 <% }) %>
              
                          </article>

                        <% } %>
  
  
                     <% } else if (reply.videoUrl !== 'none') { %> 
  
                       <video id="player" controls preload="none" style="display: block; width: 100%; height: auto; border-radius: 12px; margin-top: 13px; background-color: transparent !important; -webkit-tap-highlight-color: transparent;"
                             src="<%=R2BASE %>/<%= reply.videoUrl %>"  data-src="">
                          Your browser does not support the video tag. 
                      </video>
  
                      <% } else { %>
                        <article class="post-article" style="width: auto; height: 200px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; display: none; background: transparent;">
    
                                
                              
                                <% post.images.map((image) => { %>
            
                                  <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: calc(50% - 1px); height: 100%; object-fit: cover; object-position: center;" />
            
                                <% }) %>
             
                        </article>
                        <video id="player" controls preload="none" style="display: none; width: 100%; height: auto; border-radius: 12px; margin-top: 13px; background-color: transparent !important; -webkit-tap-highlight-color: transparent;"
                                 src="" type="video/mp4" data-src="">
                                   Your browser does not support the video tag. 
                        </video>
  
                      <% } %>
  
                    
                      <div style="display:flex; align-items:center; justify-content: space-between; gap:15px; padding: 5px 0; margin-top: 8px;">
                       
                       <div class="likes-cont" style="display: flex; align-items: center; justify-content: center;">
                           <ion-icon name="heart-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 15px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                           <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 12px; color: <%= user.userColor %>; font-weight: 600; margin-left: 3px;"> <%= reply.likes %></span>
                       </div>   
                       <div class="interactions" style="display: flex; align-items: center; justify-content: center;">
                           <ion-icon name="barcode-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 15px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                           <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 12px; color: <%= user.userColor %>; font-weight: 600; margin-left: 3px;"> <%= reply.interactions %></span>
                       </div>   
                       <ion-icon name="share-social-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 15px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                       <ion-icon name="flag-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 15px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                     
                     </div>
  
                    
                </div>
  
          </div>

        <% })  %> 
    
       

    </main>
        <!--TODO ////// SHARE REPLY CONTAINER ////  -->
      <div class="sharePost" style="display: block; position: absolute; bottom: 0; left: 0; right: 0; z-index: 5; padding: 10px 14px; background: linear-gradient(to top,rgba(5,5,8,.96) 50%,transparent);">
         
      <button id="share-link" class="tap" style="width: 100%; padding: 15px 10px; border-radius: 14px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08); display: flex; align-items: center; gap:10px;">
          <!-- ! RENDERED IN JAVASCRIPT -->
      </button>

    </div>
    
    <!-- TODO ///////  VIEW POST REPLY /////// -->

    <div class="view" id="view-to-post" style="display: none; background:rgba(5,5,8,.92)">

      <div style="padding: 13px 16px;border-bottom:1px solid rgba(255,255,255,.05); display: flex; align-items:center; gap:10px; flex-shrink:0">

          <button onclick="back()" class="back" style="padding: 7px 14px; border-radius: 10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);font-size:12px;color:rgba(237,232,224,.6)">
            ✕ Cancel
          </button>
          <div class="fd" style="flex:1;font-size:16px;font-weight:700;color:rgba(237,232,224,.8)">
            Reply
          </div>
      
          <form id="post-form" action="/post" method="post">
            <input id="userid" name="userid" value="<%= user._id %>" type="text" style="display: none;">
            <input id="postid" name="postid" value="<%= post._id %>" type="text" style="display: none;">
            <input id="post-input-elem" name="poststring" type="text" style="display: none;">
            <input id="post-image-input" name="imagesrc" type="text" style="display: none;" value="none" />
             
          <button type="submit" id="post-submit-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> class="tap" style="display: none; padding: 8px 20px;border-radius: 12px; font-size:13px; font-weight: bold;background: <%= user.userColor %>18;border: 1px solid <%= user.userColor %>52;color: <%= user.userColor %>;">Share</button>
          </form>
      </div>
      <div style="height: 78%; padding: 18px 16px; flex:1; display:flex; flex-flow: column nowrap; gap: 14px;">
        
              <div style="height: 8%; padding: 10px; display: flex; align-items: center; gap:10px;">
                 <div>
                    <div style="font-size:16px;font-weight:600;color:rgba(237,232,224,.8)">
                       <%= user.userName %>
                    </div>
                    <div <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size:13px;color: <%= user.userColor %>;">
                      Replying to @<%= post.userName %>
                    </div>
                 </div>
                 <div class="progress-wrapper" style="height: 100%; display: none; flex-flow: column nowrap; align-items: center; justify-content: center; flex-grow: 1;">
                  <h3 id="upload-status" style="font-size: 15px; color: white; width: 90%; text-align: start;">Uploading Files...</h3>     
                  <div class="prog-wrapper" style="margin-top: 5px; width: 90%; display: flex; align-items: center; justify-content: center;">
                    <progress id="overallProgress" style="width: 100%; border-radius: 50%; background-color: #1ed760;" value="0" max="100"></progress>
                    <p class="progress-text" style="color: white; margin-left: 4px; font-size: .75rem;"></p>
                  </div>
                 </div>
              </div>
      
              <div class="post-box" style="height: 88%; display: flex; flex-flow: column nowrap; overflow-x: hidden; overflow-y: scroll;">
 
                  <textarea id="post-body" placeholder="Add Caption..." maxlength="500" style="padding: 16px; border-radius: 18px 18px 0 0; font-size: 15px; line-height: 1.72; color:rgba(237,232,224,.82); background:rgba(255,255,255,.02); border: 2px solid rgba(255,255,255,.07); flex-grow: 1;"></textarea>
                
                   <!--! ///// IMAGE TO BE RENDERED IN JS AFTER MULTER UPLOAD ////  -->
                  <article id="image-article" style="width: clamp(350px, 100%, 600px); height: 60%; display: none; overflow-x: scroll; overflow-y: hidden; border-radius: 0 0 18px 18px; scroll-snap-type: inline mandatory;">

                  </article>

        
              </div>   

              <div style="text-align:right;font-size:10px;color:rgba(237,232,224,.2)">🔒 Stays within The Xikika.ke</div>
      </div>
  </div>
    
   <section id="profile-wrapper" style="display: none; position: absolute; top: 0; height: 100%; width: 100%; z-index: 4; gap: 12px; overflow-y: scroll; overflow-x: hidden;">

