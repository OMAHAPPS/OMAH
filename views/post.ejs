               <div id="poster-username" style="display: none;"><%= post.userName %></div>
               <div id="poster-followers" style="display: none;"><%= post.followers ? post.followers : 553 %></div>
               <div id="poster-following" style="display: none;"><%= post.following ? post.following : 234 %></div>
               <div id="poster-posts-length" style="display: none;"><%= post.postsLength ? post.postsLength : 3000 %></div>

              <img src="/uploads/brunoKiss-1780154542001.jpeg" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />

              <div style="flex:1; position: relative;">
                
                        <div style="font-size: 13px; font-weight: 600; color: rgba(237,232,224,.85)">
                                 <%= post.userName %> 
                                 <% if (post.userName == user.userName) { %>
                                   <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size:9px;color: <%= user.userColor %>; background: <%= user.userColor %>1a; padding: 1px 7px; border-radius: 8px; margin-left: 5px;">you</span>
                                   <% } else { %>
                                     <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; font-size:9px;color: <%= user.userColor %>; background: <%= user.userColor %>1a; padding: 1px 7px; border-radius: 8px; margin-left: 5px;">you</span>
                                 <% } %>
                        </div>

                        <h2 style="font-size: 12px; color: rgba(237,232,224,.32);" >@<%= user.userName %></h2>

                        <div class="follow-btn" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: grid; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; border: 1px solid #C04848; background-color: transparent;">
                           <h4 style="color: #C04848; font-size: .75rem;">Following</h4>
                        </div>
                             
                  </div>
                        
              </div>
 
              <p style="font-size: 16px;line-height:1.68;color:rgba(237,232,224,.8);margin-bottom:12px; white-space: pre-wrap;"><%= post.post %></p>

                     <% if (post.images.length !== 0) { %>

                     <article class="post-article" style="width: 100%; max-height: 600px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: flex; align-items: center; justify-content: flex-start; background: transparent; scroll-snap-type: inline mandatory;">

                            
                          
                            <% post.images.map((image) => { %>
        
                              <img  src="<%= R2BASE %>/<%= image %>" alt="N" style="margin-inline: 3px; width: 98%; height: auto; object-fit: cover; object-position: center; border-radius: inherit; scroll-snap-align: start;" />
        
                            <% }) %>
         
                          </article>

                   <% } else { %>

                    <article class="post-article" style="width: 100%; height: 350px; border-radius: 12px; overflow-x: scroll; overflow-y: hidden; margin-top: 13px; display: none; background: transparent;">
         
                          </article>

                   <% } %> 


              <div style="display:flex;align-items:center;gap:15px;border-top:1px solid rgba(255,255,255,.05);padding-top:10px">
                   <h2 style="font-size: 15px;color: rgba(237,232,224,.5); display: flex; align-items: center; gap: 4px; font-weight: 400; justify-content: center;">
                        18:08 <span>.</span> 04 June 26 <span>.</span> <span style="font-weight: bold; color: rgba(245, 245, 245, 0.8); margin-left: 5px;">800</span> Likes
                   </h2>
                   
              </div>

               <div style="display:flex; align-items:center; justify-content: space-around; gap:15px; padding: 20px 0 5px 0;">
                   
                   <ion-icon name="chatbubble-outline" style="font-size: 18px; font-weight: bold; color: #C04848;"></ion-icon>
                   <ion-icon name="heart-outline" style="font-size: 18px; font-weight: bold; color: #C04848;"></ion-icon>
                   <ion-icon name="share-social-outline" style="font-size: 18px; font-weight: bold; color: #C04848;"></ion-icon>
                   <ion-icon name="flag-outline" style="font-size: 18px; font-weight: bold; color: #C04848;"></ion-icon>
                   
              </div>
        </div>
        <div class="reply-header" style="display: flex; align-items: center; justify-content: flex-start; height: 20px; padding: 15px; margin-block: 5px;">
            
            <h2 style="color: rgba(237,232,224,.5); font-size: 15px; font-weight: 400;">Top Replies </h2>
                <span style="margin-left: 5px;"><ion-icon name="chevron-down-outline" style="font-size: 15px; color: rgba(237,232,224,.5); margin-top: 10px;"></ion-icon></span> 

        </div>

        <div class="reply-card" style="padding: 16px;">

