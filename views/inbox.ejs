<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
    <title>Inbox</title>
     <style>
/* ── FOUNDATION ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:#050508;color:#ede8e0;font-family:'Plus Jakarta Sans',sans-serif;-webkit-font-smoothing:antialiased}
#app{height:100%;position:relative;overflow:hidden}
canvas{position:fixed;inset:0;z-index:0;pointer-events:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,textarea{font-family:inherit;border:none;outline:none;background:none;color:inherit}
::-webkit-scrollbar{width:0;height:0}

/* ── TYPE ── */
.fd{font-family:'Playfair Display',serif}
.fs{font-family:'DM Serif Display',serif}

/* ── LAYOUT ── */
.view{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;overflow:hidden;animation:viewIn .42s cubic-bezier(.22,.61,.36,1) both}
.scroll{overflow-y:auto;-webkit-overflow-scrolling:touch}
.glass{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}

/* ── INTERACTIONS ── */
.tap{cursor:pointer;transition:transform .12s ease,opacity .12s ease;user-select:none;-webkit-user-select:none}
.tap:active{transform:scale(.91)!important;opacity:.72!important}

/* ── ANIMATIONS ── */
@keyframes viewIn      {from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes emerge      {from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn      {from{opacity:0}to{opacity:1}}
@keyframes orbIn       {from{opacity:0;transform:scale(.55)}to{opacity:1;transform:scale(1)}}
@keyframes msgPop      {from{opacity:0;transform:translateY(6px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes throb       {0%,100%{opacity:.42}50%{opacity:1}}
@keyframes drift       {0%,100%{transform:translateY(0) rotate(0deg)}40%{transform:translateY(-10px) rotate(.6deg)}75%{transform:translateY(4px) rotate(-.3deg)}}
@keyframes speak       {0%,100%{transform:scale(1.03)}50%{transform:scale(1.15)}}
@keyframes xpFill      {from{width:0%}}
@keyframes dotBlink    {0%,80%,100%{transform:scale(0);opacity:.4}40%{transform:scale(1);opacity:1}}
@keyframes effBurst    {0%{transform:scale(1);opacity:1}60%{transform:scale(1.6);opacity:.5}100%{transform:scale(2.4);opacity:0}}
@keyframes storyPulse  {0%,100%{box-shadow:0 0 0 0 var(--sc)}50%{box-shadow:0 0 0 4px var(--sc)}}
@keyframes heartbeat   {0%,100%{transform:scale(1)}14%{transform:scale(1.1)}28%{transform:scale(1)}42%{transform:scale(1.06)}}
@keyframes shimmer     {0%{background-position:-200% center}100%{background-position:200% center}}
</style>
</head>
<body>

   <header style="position: relative; height: 10%; display: flex; align-items: center; gap: 12px; padding: 18px 16px; border-bottom: 1px solid rgba(255,255,255,.08);">
        
        <% if (origin) { %>
            <a href="/post/<%= origin %>" style="font-size: 20px; font-weight: 700; color: rgba(237,232,224,.85); display: flex; align-items: center; gap:6px">
                <ion-icon name="arrow-back-outline"></ion-icon>
            </a> 
        <% } else { %>
            <a href="/home" style="font-size: 20px; font-weight: 700; color: rgba(237,232,224,.85); display: flex; align-items: center; gap:6px">
                <ion-icon name="arrow-back-outline"></ion-icon>
            </a>     
        <% } %>

        
        <div id="prof" onclick="displayNav()" style=" font-size: 15px; font-weight: 600; color: rgba(237,232,224,.85); display: flex; align-items: center; gap:6px; flex: 1;">

             <!-- ! element Placeholders for profile image and user info -->
               <div id="poster-username" style="display: none;"><%= userMessaged.userName %></div>
               <div id="poster-followers" style="display: none;"><%= userMessaged.totalFollowers %></div>
               <div id="poster-following" style="display: none;"><%= userMessaged.totalFollowing %></div>
               <div id="poster-posts-length" style="display: none;"><%= userMessaged.totalPosts %></div>
               <div id="poster-user-handle" style="display: none;">@<%= userMessaged.userHandle !== 'none' ? userMessaged.userHandle : userMessaged.userName %></div>

               <% if (userMessaged.userDP !== 'none') { %>
                <img onclick="displayNav()" src="<%= R2BASE %>/<%= userMessaged.userDP %>" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" /> 
               <% } else { %>
                <img onclick="displayNav()" src="/placeholder.jpg" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />              
               <% } %>


            <div onclick="displayNav()" class="name-cont" style="display: flex; flex-direction: column; gap:4px">

                <h2 onclick="displayNav()" style="font-size: 15px; font-weight: 600; color: rgba(237,232,224,.85);"><%= userMessaged.userName %></h2>

                <div onclick="displayNav()" style="display: flex; align-items: center; gap:4px">
                   <div style="display: none; width: 6px; height: 6px; border-radius: 50%; background: #1ed760; box-shadow:0 0 6px #1ed760; animation: throb 1.8s ease-in-out infinite;"></div>
                   <span style="display: none; font-size: 11px; color: rgba(237,232,224,.45);">Online</span>
                   <span style="font-size: 11px; color: rgba(237,232,224,.45);">Last seen 2h ago</span>
                </div>
                
            </div>
            
            
        </div>    
        
        <% if (!followingStatus) { %>
            <button class="follow-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="opacity: 1; outline: none; position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: grid; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; background-color: <%= userReq.userColor %>; transition: all .4s ease-out;">
                <h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>
            </button>  
            <button class="unfollow-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="outline: none; position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: none; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; border: 1px solid <%= userReq.userColor %>; background-color: transparent; transition: all .4s ease-out;">
                <h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>
            </button>
        <% } else { %>
                <button class="unfollow-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="outline: none; position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: grid; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; border: 1px solid <%= userReq.userColor %>; background-color: transparent; transition: all .4s ease-out;">
                   <h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>
                </button>
                <button class="follow-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="opacity: 1; outline: none; position: absolute; right: 10px; top: 50%; transform: translateY(-50%); display: none; place-content: center; padding: 15px; height: 30px; width: fit-content; border-radius: 15px; background-color: <%= userReq.userColor %>; transition: all .4s ease-out;">
                   <h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>
                </button> 
        <% } %>

            

   </header>

    <main style="height: 80%; display: flex; flex-direction: column; gap: 12px; padding: 16px; overflow-y: scroll; overflow-x: hidden; scroll-snap-type: y mandatory; scroll-padding-block: 10px;">

       
        
        <div class="receiver-cont" style="align-self: flex-start; max-width: 72%; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 0 18px 18px 18px; padding: 5px 16px; animation: msgPop .28s cubic-bezier(.22,.61,.36,1) both; scroll-snap-align: end;">
            <!-- <article style="width: 100%;">
                <img src="/uploads/mwatiJS-1780147920696.jpeg" alt="" width="98%" height="auto" style="border-radius: 15px; object-fit: cover;" />
            </article> -->
            <p style="white-space: pre-wrap; margin-block: 8px; color: rgba(237,232,224,.75); font-size: 16px;">Hey! I'm doing great, thanks for asking. How about you?Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
            <div class="timestamp" style="font-size: 11px; color: rgba(237,232,224,.45); text-align: right; margin-top: 4px; display: flex; align-items: center; justify-content: flex-end;">
                <span style="display: inline-block; margin-right: 4px;"><ion-icon name="checkmark-done-outline" style="font-size: 1.1rem; color: rgb(37, 134, 224);"></ion-icon></span>
                <p> 2:30 PM</p>
            </div>

        </div>

        
        <div class="sender-cont" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="align-self: flex-end; max-width: 72%; background: <%= userReq.userColor %>51; border: 1px solid rgba(255,255,255,.07); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 18px 0 18px 18px; padding: 5px 16px; animation: msgPop .28s cubic-bezier(.22,.61,.36,1) both; scroll-snap-align: end;">
            <!-- <article style="width: 100%;">
                <img src="/uploads/mwatiJS-1780147920696.jpeg" alt="" width="98%" height="auto" style="border-radius: 15px; object-fit: cover;" />
            </article> -->
            <p style="white-space: pre-wrap; margin-block: 4px; color: rgba(237,232,224,.95); font-size: 16px;">Hey! I'm doing great, thanks for asking. How about you?</p>
            <div class="timestamp" style="font-size: 11px; color: rgba(237,232,224,.45); text-align: right; margin-top: 4px; display: flex; align-items: center; justify-content: flex-end;">
                <span style="display: inline-block; margin-right: 4px;"><ion-icon name="checkmark-done-outline" style="font-size: 1.1rem; color: rgb(37, 134, 224);"></ion-icon></span>
                <p>2:30 PM</p>
            </div>
        </div>
      
        
      
    </main>
    <footer style="height: 10%; padding-left: 12px; display: flex; align-items: center; gap: 12px;">

        <div class="cont" style="height: 100%; width: 95%; display: flex; align-items: center; gap: 12px;">

            <textarea id="text-area" type="text" placeholder="Message" style="background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); font-size: 16px; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 10px; padding: 10px; height: 85%; padding: 12px 16px; color: rgba(237,232,224,.85); flex: 1;"></textarea>

            <div class="media-send-cont" style="display: flex; align-items: center; gap: 8px; justify-content: flex-end; height: 100%; width: fit-content;">
                <ion-icon name="attach" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 2.2rem; display: block; color: <%= userReq.userColor %>;"></ion-icon> 
                <button id="send-msg-btn" style="background-color: #1ed760; color: #050508; height: 45px; width: 45px; border-radius: 50%; font-weight: 600; display: none; justify-content: center; align-items: center;"><ion-icon name="send"></ion-icon></button>
            </div>

        </div>
    </footer>    

   <section id="single-profile-wrapper" style="display: none; position: absolute; top: 0; height: 100%; width: 100%; z-index: 4; gap: 12px; overflow-y: scroll; overflow-x: hidden;">

        <div class="overlay-single" style="display: none; position: absolute; inset: 0; height: 100%; width: 100%; z-index: 3; background-color: rgba(128, 128, 128, 0.4);"></div>

        <nav class="single-profile-content" style=" position: absolute; top: 100%; z-index: 4; border-radius: 50px 50px 0 0; width: 100%; height: 50%; background-color: #050508; touch-action: none; will-change: transform;">

                <div class="scroll-icon" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="width: 40px; height: 4px; background-color: <%= userReq.userColor %>; border-radius: 2px; position: absolute; top: 20px; left: 50%; transform: translateX(-50%);"></div>    

                <div id="single-profile-info-cont" style="margin-top: 20px; display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 24px 16px;">

                    <img src="/uploads/brunoKiss-1780154542001.jpeg" alt="" width="100" height="100" style="border-radius: 50%; object-fit: cover;" />

                    <h2 style="font-size: 18px; font-weight: 700; color: rgba(237,232,224,.85);"></h2>

                    <p style="font-size: 14px; color: rgba(237,232,224,.45);"></p>

                    <div class="follow-wrapper" style="display: flex; justify-content: space-around; align-items: center; width: 100%; height: 40px;">
                         
                           <div class="following-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 5px;">
                        <p id="following" style="color: white; font-size: 16px; font-weight: bold;"></p>
                        <span style="color: rgba(237,232,224,.45);">Following</span>
                      </div>
                      <div class="followers-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 5px;">
                        <p id="followers" style="color: white; font-size: 16px; font-weight: bold;"></p>
                        <span style="color: rgba(237,232,224,.45);">Followers</span>

                      </div>
                      <div class="posts-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 5px;">
                        <p id="postsTotal" style="color: white; font-size: 16px; font-weight: bold;"></p>
                        <span style="color: rgba(237,232,224,.45);">Posts</span>
                      </div>
                    </div>

                    <div class="interact" style="width: 100%; background-color: transparent; margin-top: 10px; display: flex; justify-content: space-evenly; align-items: center;">

                      

                    </div>


                </div>  
        </nav>
        
    </section>



    
<script src="/socket.io/socket.io.js"></script>
<script>

    const socket = io({ auth: { userId: '<%= userReq._id %>' }, ackTimeout: 5000, retries: 3 })

    // MESSAGING LOGIC WITH RETRIES OPTION

    









    const dot = (col) => { return `<div style="width: 6px; height: 6px; border-radius: 50%; background: ${col}; box-shadow:0 0 6px ${col}; animation: throb 1.8s ease-in-out infinite;flex-shrink:0"></div>`; }
    const userColor = '<%= userReq.userColor %>'
    
    const unfollowBtn = document.querySelector('.unfollow-btn')
    const followBtn = document.querySelector('.follow-btn')

    followBtn.addEventListener('click', async (e) => {

          e.target.innerHTML = `${dot(userColor)}`
          e.target.style.backgroundColor = 'transparent'
          e.target.style.border = `1px solid ${userColor}`
          e.target.disabled = true 

          const payload = { recipientId: '<%= userMessaged._id %>' }

          try {
            
              const response = await socket.timeout(5000).volatile.emitWithAck("follow-request", payload)
      
              if (response.success) {   // follow instance success
      
                      e.target.style.display = 'none'
                      e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                      e.target.style.backgroundColor = `${userColor}`
                      e.target.disabled = false
                      unfollowBtn.style.display = 'grid'
                      console.log(response)
                 
      
              } else {
                
                      e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                      e.target.style.backgroundColor = `${userColor}`
                      e.target.style.border = 'none'
                      e.target.disabled = false       
                      console.log(response)
               
              }

          } catch (error) {   //ACKTIMEOUT

                      e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                      e.target.style.backgroundColor = `${userColor}`
                      e.target.style.border = 'none'
                      e.target.disabled = false
                      setTimeout(() => {
                          e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                      }, 500)    
            
          }


    })

    unfollowBtn.addEventListener('click', async (e) => {
              
            e.target.innerHTML = `${dot(userColor)}`
            e.target.disabled = true

            const payload = { recipientId: '<%= userMessaged._id %>' }

            try {
                
                const response = await socket.timeout(5000).volatile.emitWithAck("unfollow-request", payload)
    
                if (response.success) {  // UNFOLLOW SUCCESS INSTANCE
    
                    e.target.disabled = false
                    e.target.style.display = 'none'
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                    followBtn.style.display = 'grid'
                    console.log(response)
    
                } else {    // UNFOLLOW INSTANCE FAILED
    
                    e.target.disabled = false
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                    console.log(response)
                }

            } catch (error) {

                    e.target.disabled = false
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                    setTimeout(() => {
                        e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                    }, 500)
                
            }

    })

    const textArea = document.getElementById('text-area')
    const sendMsgBtn = document.getElementById('send-msg-btn')

    textArea.addEventListener('keyup', () => {
        if (textArea.value.trim() !== '') {
            sendMsgBtn.style.display = 'flex'
            sendMsgBtn.disabled = false
        } else {
            sendMsgBtn.style.display = 'none'
            sendMsgBtn.disabled = true
            textArea.value = textArea.value.trimStart()
        }
    })
 

    const modalSingle = document.querySelector('.single-profile-content')

    const profileHeader = document.querySelector('#prof')

    function displayNav () {
          
          // Populate modal with profile info (placeholder for now)
          const profileInfo = {
              userName: profileHeader.children[0].textContent,
              userProfilePic: profileHeader.children[5].getAttribute('src'),
              userHandle: profileHeader.children[4].textContent,
              userStats: {
                  posts: profileHeader.children[3].textContent,
                  followers: profileHeader.children[1].textContent,
                  following: profileHeader.children[2].textContent
              } 
          }
         
        
          const singleProfileContainer = document.querySelector('#single-profile-info-cont')
          
          singleProfileContainer.querySelector('img').src = profileInfo.userProfilePic
          singleProfileContainer.querySelector('h2').textContent = profileInfo.userName
          singleProfileContainer.querySelector('p').textContent = profileInfo.userHandle
          singleProfileContainer.querySelector('#following').textContent = profileInfo.userStats.following
          singleProfileContainer.querySelector('#followers').textContent = profileInfo.userStats.followers
          singleProfileContainer.querySelector('#postsTotal').textContent = profileInfo.userStats.posts

          document.querySelector('.interact').innerHTML = `<a id="link-to-profile" class="stop-fetch" href="/user/<%= userMessaged._id %>" class="stop-fetch" style="text-decoration: none; display: flex; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                             <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= userReq.userColor %>;transform: msFilter"><path d="M19 2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h4l3 3 3-3h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-7 3c1.727 0 3 1.272 3 3s-1.273 3-3 3c-1.726 0-3-1.272-3-3s1.274-3 3-3zM7.177 16c.558-1.723 2.496-3 4.823-3s4.266 1.277 4.823 3H7.177z"></path></svg>
                                                             <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= userReq.userColor %>;">View Profile</h2>
                                                           </a>
                                                           `
          document.querySelector('.overlay-single').style.display = 'block'
          document.getElementById('single-profile-wrapper').style.display = 'block'
          setTimeout(() => {
              modalSingle.style.transition = 'top 0.3s ease-out'
              modalSingle.style.top = '50%'
          }, 200)
      }

    


    let singlestartY = 0
    let singlecurrentY = 0
    let singledragging = false

    modalSingle.addEventListener('touchstart', (e) => {
        singlestartY = e.touches[0].clientY
        singledragging = true
        
         modalSingle.style.transition = 'none'

    })

    modalSingle.addEventListener('touchmove', (e) => {
        if (!singledragging) return;
        singlecurrentY = e.touches[0].clientY
        const deltaY = singlecurrentY - singlestartY

        // Only drag downward
        if (deltaY > 0) {
            modalSingle.style.transform = `translateY(${deltaY}px)`

            // fade background
            const opacity = 0.4 - deltaY / 500
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, ${opacity})`
        }
    })

    modalSingle.addEventListener('touchend', (e) => {
        singledragging = false
        const deltaY = singlecurrentY - singlestartY

        if (deltaY > 100) {
            modalSingle.style.transition = 'transform 0.3s ease-out'
            modalSingle.style.transform = `translateY(100%)`
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0)`
            setTimeout(() => {
                    document.getElementById('single-profile-wrapper').style.display = 'none'
                    document.querySelector('.overlay-single').style.display = 'none'
                    document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0.4)`
                    modalSingle.style.transform = 'translateY(0)'
    
            }, 200)
        } else {
            modalSingle.style.transition = 'transform 0.3s ease-out'
            modalSingle.style.transform = `translateY(0)`
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0.4)`
        }
    })

    document.querySelector('.overlay-single').addEventListener('click', () => {
        modalSingle.style.transition = 'top 0.3s ease-out'
        modalSingle.style.top = '100%'
        document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0)`
        setTimeout(() => {
            document.getElementById('single-profile-wrapper').style.display = 'none'
            document.querySelector('.overlay-single').style.display = 'none'
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0.4)`
            modalSingle.style.top = '100%'
        }, 300)
    })



</script>    
</body>
</html>