    <footer style="height: 10%; padding-left: 12px; display: flex; align-items: center; gap: 12px;">

        <div class="cont" style="height: 100%; width: 95%; display: flex; align-items: center; gap: 12px;">

            <textarea id="text-area" type="text" placeholder="Message" style="background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 10px; padding: 10px; height: 85%; padding: 12px 16px; color: rgba(237,232,224,.85); flex: 1;"></textarea>

            <div class="media-send-cont" style="display: flex; align-items: center; gap: 8px; justify-content: flex-end; height: 100%; width: fit-content;">
                <ion-icon name="attach" style="font-size: 2.2rem; display: block; color: #C04848;"></ion-icon> 
                <button id="send-msg-btn" style="background-color: #1ed760; color: #050508; height: 45px; width: 45px; border-radius: 50%; font-weight: 600; display: none; justify-content: center; align-items: center;"><ion-icon name="send"></ion-icon></button>
