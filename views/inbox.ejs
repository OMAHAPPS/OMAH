<script src="/socket.io/socket.io.js"></script>
<script>

    const socket = io({ auth: { userId: '<%= userReq._id %>' } })

    // MESSAGING LOGIC WITH RETRIES OPTION

    

   
    const textArea = document.getElementById('text-area')
    const sendMsgBtn = document.getElementById('send-msg-btn')
    const chatContainer = document.getElementById('chat-container')


    const MAX_LOCAL_MESSAGES = 200 
    const currentUserId = '<%= parties.sender %>'
    const recipientId = '<%= parties.recipient %>'

  
        
    

    function generateOneOnOneRoomId(userA_Id, userB_Id) {
        
       // 1. Put both IDs into an array
       const ids = [userA_Id, userB_Id]
  
       // 2. Sort them alphabetically (e.g., ['alice', 'bob'] instead of ['bob', 'alice'])
       ids.sort()
  
       // 3. Join them with a delimiter to create a single immutable string
      return `dm_${ids[0]}_${ids[1]}`
}
    
    function formatDividerDate(dateObj) {
       const today = new Date();
       const yesterday = new Date();
       yesterday.setDate(today.getDate() - 1);

       if (dateObj.toLocaleDateString() === today.toLocaleDateString()) {
            return 'Today';
       } else if (dateObj.toLocaleDateString() === yesterday.toLocaleDateString()) {
            return 'Yesterday';
       } else {
            // Returns clean format like "June 22, 2026"
            return dateObj.toLocaleDateString([], { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
       }
     }

    const roomId = generateOneOnOneRoomId(currentUserId, recipientId)

    let messageState = JSON.parse(localStorage.getItem(`chat_history_${recipientId}`)) || []
    

      textArea.addEventListener('keyup', () => {
        if (textArea.value.trim() !== '') {
            sendMsgBtn.style.display = 'flex'
            sendMsgBtn.disabled = false
            socket.emit('typing', roomId)
            
        } else {
            sendMsgBtn.style.display = 'none'
            sendMsgBtn.disabled = true
            textArea.value = textArea.value.trimStart()
        }
    })

    
   
    function saveAndRender () {
       
         messageState.sort((a,b) => a.timestamp - b.timestamp)

         if (messageState.length > MAX_LOCAL_MESSAGES) {

            messageState.slice(-MAX_LOCAL_MESSAGES)
         }

         try {
            
            localStorage.setItem(`chat_history_${recipientId}`, JSON.stringify(messageState))

         } catch (error) {
            
            if (error.name === 'QuotaExceededError') {
                messageState.slice(-100)      // Cut for recovery
                localStorage.setItem(`chat_history_${recipientId}`, JSON.stringify(messageState))
            } 
         }

         renderMessages()
    }

    function renderMessages () {

         chatContainer.innerHTML = '' // Wipe DOM to prevent rendering bugs

         let previousMessageDateString = null

          messageState.forEach(msg => {
             // 1. Convert the microsecond timestamp into a localized date string (e.g., "6/22/2026")
             const currentMessageDate = new Date(msg.timestamp)
             const currentMessageDateString = currentMessageDate.toLocaleDateString()

             // 2. MIDNIGHT CHECK: If this day is different from the last message's day, inject a separator
             if (currentMessageDateString !== previousMessageDateString) {
                  const dateDivider = document.createElement('div')
                  dateDivider.className = 'chat-date-divider'
      
                  // Optional enhancement: Render "Today" or "Yesterday" instead of raw dates
                  dateDivider.textContent = formatDividerDate(currentMessageDate)
      
                  chatContainer.appendChild(dateDivider)
      
                  // Update our tracking anchor to the new day
                  previousMessageDateString = currentMessageDateString
              }

              // 3. RENDER THE STANDARD CHAT BUBBLE (Existing Logic)
              const msgElement = document.createElement('div')
              const isMe = msg.senderId === currentUserId;
              msgElement.className = `${isMe ? 'sender-cont' : 'receiver-cont'}`

              let tickHtml = isMe ? (msg.status == 'seen' ? '<span id="sender-status-span" style="display: inline-block; margin-right: 4px;"><ion-icon name="checkmark-done-outline" style="font-size: 1.1rem; color: rgb(37, 134, 224);"></ion-icon></span>' : msg.status == 'delivered' ? '<span id="sender-status-span" style="display: inline-block; margin-right: 4px;"><ion-icon name="checkmark-done-outline" style="font-size: 1.1rem; color: grey;"></ion-icon></span>' : msg.status == 'sent' ? '<span style="display: inline-block; margin-right: 4px;"><ion-icon name="checkmark-outline" style="font-size: 1.1rem; color: grey;"></ion-icon></span>' : msg.status == 'sending' ? '<span style="display: inline-block; margin-right: 4px;"><ion-icon name="time-outline" style="font-size: 1.1rem; color: grey;"></ion-icon></span>' : '' ) : '';

              if (isMe) {
                msgElement.style.backgroundColor = '<%= userReq.userColor %>41'
              }
              if (msg.status == 'failed') {
                  msgElement.classList.add('failed')
                   msgElement.innerHTML = ` 
                                      <p id="text" style="white-space: pre-wrap; margin-bottom: 10px; margin-top: 5px; color: rgba(237,232,224,.95); font-size: 16px;">${msg.text}</p>

                                         <div class="timestamp" style="font-size: 11px; color: rgba(237,232,224,.45); text-align: right; margin-top: 4px; display: flex; align-items: center; justify-content: flex-end;">

                                          ${tickHtml}

                                          <p id="localetime" >${currentMessageDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</p>

                                         </div> 

                                         
                                         <button class="retry-btn" onclick="retryMessage('${msg.id}')" style="outline: none; cursor: pointer; border: none; position: absolute; bottom: 0; left: -65px; color: red; width: 70px; display: flex; align-items: center; justify-content: center; gap: 3px; font-size: .85rem;">
                                            <ion-icon name="repeat-outline" style="pointer-event: none; color: red; font-size: 1.05rem;"></ion-icon>
                                             Retry
                                         </button>
                                      
                                     `
    

              } else {

                  msgElement.innerHTML = ` 
                                          <p id="text" style="white-space: pre-wrap; margin-bottom: 10px; margin-top: 5px; color: rgba(237,232,224,.95); font-size: 16px;">${msg.text}</p>
    
                                             <div class="timestamp" style="font-size: 11px; color: rgba(237,232,224,.45); text-align: right; margin-top: 4px; display: flex; align-items: center; justify-content: flex-end;">
    
                                              ${tickHtml}
    
                                              <p id="localetime" >${currentMessageDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</p>
    
                                             </div> 
    
                                             
                                             <button class="fs" style="outline: none; cursor: pointer; border: none; position: absolute; bottom: 0; left: -65px; color: red; width: 70px; display: none; align-items: center; justify-content: center; gap: 3px; font-size: .85rem;">
                                                <ion-icon name="repeat-outline" style="color: red; font-size: 1.05rem;"></ion-icon>
                                                 Retry
                                             </button>
                                          
                                         `
        
              }
    
    
              chatContainer.appendChild(msgElement)
             
          })

      }
      document.querySelector('#alert-scroll').addEventListener('click', (e) => {
          
        e.target.style.display = 'none'
        chatContainer.scrollTo({
            top: chatContainer.scrollHeight,
            behavior: 'smooth'
        })
         
      })

    function updateMessageStatus (id, newStatus) {
           
           const msg = messageState.find(m => m.id === id)

           if (msg) {
              msg.status = newStatus
           }
           saveAndRender()
    }
    
    const retryMessage = async (id) => {

         const msg = messageState.find(m => m.id === id)
         if (msg) {
            msg.status = 'sending'
         }
         saveAndRender();

         try {

            const response = await socket.timeout(5000).emitWithAck('sendMessage', msg)

            if (response.success) {
                updateMessageStatus(msg.id, 'sent')
            } else {
                updateMessageStatus(msg.id, 'failed')
                console.log(response.error)
            }
            
         } catch (error) {
             
             updateMessageStatus(msg.id, 'failed')
             console.log('ACK TIMEOUT')
         }

    }
    
    function clearChatHistory(recipientId) {
       // 1. Clear the local runtime state variable
       messageState = []
  
       // 2. Remove only the specific chat key from local storage
       localStorage.removeItem(`chat_history${recipientId}`)
  
       // 3. Update the UI to show an empty screen
       renderMessages()
    }
    
    window.addEventListener('DOMContentLoaded', () => {

          clearChatHistory(recipientId)

           const scrollToBottom = () => {
             chatContainer.scrollTo({
               top: chatContainer.scrollHeight, // Direct math to bottom container limit
               behavior: 'smooth'
             })
           }

           // 2. Initialize the observer engine to listen for DOM child changes
           const observer = new MutationObserver(() => {
             scrollToBottom();
           
             // ADD THE UNREAD MESSAGE ICON TO MAKE USER SCROLL TO BOTTOM
             document.querySelector('#alert-scroll').style.display = 'flex'
             document.querySelector('#alert-scroll').style.opacity = 1
             setTimeout(() => {
                document.querySelector('#alert-scroll').style.opacity = 0
             }, 5000)
             
           // Optional: Disconnect after first successful load if you only want it on page-load
           observer.disconnect() 
           })

           // 3. Start monitoring the chat box layout 
           observer.observe(chatContainer, { 
                   childList: true, // Triggers when child message nodes are added/cleared
                   subtree: true    // Triggers if items change inside nested wrappers
                 })

           
        
     })
    
    function deduplicateAndSave () {

        const uniqueMap = new Map()

        // Loop through state; newer duplicates overwrite older ones
        messageState.forEach((msg) => {
           uniqueMap.set(msg.id, msg)
        })

        // Convert map back into a clean sorted array
        messageState = Array.from(uniqueMap.values())
        // saveBack to localS AND RENDER
        saveAndRender()
    }

    const loadHistoryFromServer = async (userId, roomId) => {
         
         try {

            const response = await fetch(`/api/dm-history/messages?roomId=${roomId}`)
            const serverResponse = await response.json()

            if (serverResponse.success) {

                // serverMessages should be an array of objects matching your schema { id, senderId, receiverId, text, timestamp }
                // Dont mark Messages from server to custom states since updates are happenning on emits    
                const validatedMessages = serverResponse.messages
    
                // match with realtime messages to handle race conditions
                messageState = [...messageState, ...validatedMessages]
    
                // De-duplicate, sort, and save to LocalStorage again
                deduplicateAndSave()
            } else {
                return;
            }

         } catch (error) {

            console.log('Failed to recover Chat History: ' + error)
            return;
            
         }
    }

    
   
    // 2. THE ENTRY TRUCK: Fire actions the millisecond we connect
    socket.on('connect', () => {

       console.log('🔗 WebSocket Connection Established! Socket ID:', socket.id)

       const joinPayload = { roomId: roomId, userId: currentUserId }

       // Send credentials to backend to join the isolated chat room pipeline
       socket.emit('joinRoom', joinPayload)

       // Safe context zone: Start loading historical cache state data now
       loadHistoryFromServer(currentUserId, roomId)
  
       // Enable the input form since the connection channel is ready
       document.getElementById('text-area').disabled = false
       document.getElementById('send-msg-btn').disabled = false
       
    })

    socket.on('messages_marked_seen', (data) => {

         if (data.roomId === roomId && data.readerId === currentUserId) {
                
                messageState.forEach(msg => {

                    if (msg.senderId === currentUserId) { // if i was the one who sent the messages i should see blue ticks
                        
                         msg.status = 'seen'
                    }
                })

                saveAndRender()   // swaps grey ticks to blue ticks
         }
     })

    socket.on('typing', (roomId) => {
       document.querySelector('#last-seen').textContent = 'Typing..'
       document.querySelector('#last-seen').style.color = '<%= userReq.userColor %>'
    })

    socket.on('finished-typing', (roomId) => {
         document.querySelector('#last-seen').textContent = 'Online'
          document.querySelector('#last-seen').style.color = 'grey'
    })
    
    const createNewMessage = async () => {

         if (!textArea.value.trim()) return;

         const newMessage = {
            id: crypto.randomUUID(),
            senderId: currentUserId,
            receiverId: roomId, // The roomId acts as the destination router target
            text: textArea.value,
            timestamp: Date.now(),
            status: 'sending'
         }

         messageState.push(newMessage)
         
         textArea.value = '' // Reset form box
         sendMsgBtn.style.display = 'none' // Hide sendMessage Btn 
         socket.emit('stop-typing', roomId)
         saveAndRender()
         chatContainer.scrollTo({
            top: chatContainer.scrollHeight,
            behavior: "instant"
         })

          // EMIT EVENT: Safe to trigger since joinRoom registration already processed
         
        try {
            
            const response = await socket.timeout(5000).emitWithAck('sendMessage', newMessage)

              if (response.success) {
                                            // ADD ALL ADDITIONAL INSTANCES NESTED TO ALWAYS RETURN THE ACK({}) BLOCK
                 // THIS SHOULD FIRE ONLY WHEN MESSAGE IS JUST SAVED BUT NOT DELIVERED    INTERCEPTS MIGHT OCCUR FOR UI
                 updateMessageStatus(newMessage.id, response.newStatus)
                 console.log('New message sent: ' + response.newStatus)


              } else {  // THIS BLOCK WILL CARRY ALL SERVER INSTANCE ERRORS EVERY TIME THE SERVER FAILS TO SAVE OR UPDATE BUCKETS

                 updateMessageStatus(newMessage.id, response.newStatus)
                 console.log(response.error)
              }

        } catch (error) {

            updateMessageStatus(newMessage.id, 'failed')
            console.log('ACK TIMEOUT')
            
        }

      
    }

    sendMsgBtn.addEventListener('click', createNewMessage)

    // ON RECEIVING MESSAGE BUT NOT CURRENTLY IN THE ROOM DOUBLE GREY TICK TRIGGER
    socket.on('receiveMessage_background', (incomingMsg, callback) => {
        
         callback({ received: true })  // critical to nullify the timeout sent from io.to(me) ACKNOWLEDGMENT TO SERVER

          const messageExists = messageState.some(m => m.id === incomingMsg.id)
          console.log('I Have Successfully received Message from: ' + incomingMsg.senderId)
          


          if (!messageExists) { // New message instance just about incoming

             if (roomId === incomingMsg.receiverId) {  // receiver is currently inside Chat window... skip grey ticks and instantly update to SEEN /BLUETICKS
                  
                   incomingMsg.status = 'seen'
                  // EMIT IMMEDIATE SEEN RECEIPT TO SERVER   
                   messageState.push(incomingMsg)
                   saveAndRender() 
             
                   document.querySelector('#alert-scroll').style.display = 'flex'
                   document.querySelector('#alert-scroll').style.opacity = 1
                   setTimeout(() => {
                     document.querySelector('#alert-scroll').style.opacity = 0
                   }, 5000)
                
                   socket.emit('message_read', { msgId: incomingMsg.id, roomId: incomingMsg.receiverId, userId: currentUserId })
                  
                } 
    
            }
    }) 

    socket.on('message_delivered_receipt', (data) => {
         // Performance Guard: Only process if the update belongs to the active chat screen
         if (data.roomId === roomId) {
    
            // 1. Locate the exact message object reference sitting inside your array state
            const targetMsg = messageState.find(m => m.id === data.msgId);
    
           if (targetMsg) {
               // 2. Flip the state flag. Because objects are passed by reference, 
               // this alters it directly inside the master messageState array  MIGHT BE OVERWRITTEN IF SERVER ACTUALLY FAILED TO UPDATE THE MESSAGE
               targetMsg.status = 'delivered'
               console.log('CHANGED MSG TO DELIVERED')
               // 3. Commit the change to localStorage and clear/redraw the DOM bubbles
               saveAndRender() 
            }
          }
    });

    socket.on('message_read_receipt', (data) => {

        // Perfomance Guard: Only update if you are in chat window to avoid getting wrong chatHistory
         if (data.roomId === roomId) {

             const readMsg = messageState.find(m => m.id === data.msgId)
             
             if (readMsg) {
                readMsg.status = 'seen'
                console.log('CHANGED SENT STATUS TO SEEN')
                saveAndRender()
             }
         }
    })

    // UNLOAD EVENT LISTENERS FOR HANDLING LEAVING ROOMS
    
   
    
    
   

    const dot = (col) => { return `<div style="width: 6px; height: 6px; border-radius: 50%; background: ${col}; box-shadow:0 0 6px ${col}; animation: throb 1.8s ease-in-out infinite;flex-shrink:0"></div>`; }
    const userColor = '<%= userReq.userColor %>'
    
    const unfollowBtn = document.querySelector('.unfollow-btn')
    const followBtn = document.querySelector('.follow-btn')

    followBtn.addEventListener('click', async (e) => {

          e.target.innerHTML = `${dot(userColor)}`
          e.target.style.backgroundColor = 'transparent'
          e.target.style.border = `1px solid ${userColor}`
          e.target.disabled = true 

          const payload = { recipientId: '<%= userMessaged._id %>' }

          try {
            
              const response = await socket.timeout(5000).volatile.emitWithAck("follow-request", payload)
      
              if (response.success) {   // follow instance success
      
                      e.target.style.display = 'none'
                      e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                      e.target.style.backgroundColor = `${userColor}`
                      e.target.disabled = false
                      unfollowBtn.style.display = 'grid'
                      console.log(response)
                 
      
              } else {
                
                      e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                      e.target.style.backgroundColor = `${userColor}`
                      e.target.style.border = 'none'
                      e.target.disabled = false       
                      console.log(response)
               
              }

          } catch (error) {   //ACKTIMEOUT

                      e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                      e.target.style.backgroundColor = `${userColor}`
                      e.target.style.border = 'none'
                      e.target.disabled = false
                      setTimeout(() => {
                          e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                      }, 500)    
            
          }


    })

    unfollowBtn.addEventListener('click', async (e) => {
              
            e.target.innerHTML = `${dot(userColor)}`
            e.target.disabled = true

            const payload = { recipientId: '<%= userMessaged._id %>' }

            try {
                
                const response = await socket.timeout(5000).volatile.emitWithAck("unfollow-request", payload)
    
                if (response.success) {  // UNFOLLOW SUCCESS INSTANCE
    
                    e.target.disabled = false
                    e.target.style.display = 'none'
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                    followBtn.style.display = 'grid'
                    console.log(response)
    
                } else {    // UNFOLLOW INSTANCE FAILED
    
                    e.target.disabled = false
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                    console.log(response)
                }

            } catch (error) {

                    e.target.disabled = false
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                    setTimeout(() => {
                        e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                    }, 500)
                
            }

    })

    

    const modalSingle = document.querySelector('.single-profile-content')

    const profileHeader = document.querySelector('#prof')

    function displayNav () {
          
          // Populate modal with profile info (placeholder for now)
          const profileInfo = {
              userName: profileHeader.children[0].textContent,
              userProfilePic: profileHeader.children[5].getAttribute('src'),
              userHandle: profileHeader.children[4].textContent,
              userStats: {
                  posts: profileHeader.children[3].textContent,
                  followers: profileHeader.children[1].textContent,
                  following: profileHeader.children[2].textContent
              } 
          }
         
        
          const singleProfileContainer = document.querySelector('#single-profile-info-cont')
          
          singleProfileContainer.querySelector('img').src = profileInfo.userProfilePic
          singleProfileContainer.querySelector('h2').textContent = profileInfo.userName
          singleProfileContainer.querySelector('p').textContent = profileInfo.userHandle
          singleProfileContainer.querySelector('#following').textContent = profileInfo.userStats.following
          singleProfileContainer.querySelector('#followers').textContent = profileInfo.userStats.followers
          singleProfileContainer.querySelector('#postsTotal').textContent = profileInfo.userStats.posts

          document.querySelector('.interact').innerHTML = `<a id="link-to-profile" class="stop-fetch" href="/user/<%= userMessaged._id %>" class="stop-fetch" style="text-decoration: none; display: flex; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                             <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= userReq.userColor %>;transform: msFilter"><path d="M19 2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h4l3 3 3-3h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-7 3c1.727 0 3 1.272 3 3s-1.273 3-3 3c-1.726 0-3-1.272-3-3s1.274-3 3-3zM7.177 16c.558-1.723 2.496-3 4.823-3s4.266 1.277 4.823 3H7.177z"></path></svg>
                                                             <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= userReq.userColor %>;">View Profile</h2>
                                                           </a>
                                                           `
          document.querySelector('.overlay-single').style.display = 'block'
          document.getElementById('single-profile-wrapper').style.display = 'block'
          setTimeout(() => {
              modalSingle.style.transition = 'top 0.3s ease-out'
              modalSingle.style.top = '50%'
          }, 200)
      }

    


    let singlestartY = 0
    let singlecurrentY = 0
    let singledragging = false

    modalSingle.addEventListener('touchstart', (e) => {
        singlestartY = e.touches[0].clientY
        singledragging = true
        
         modalSingle.style.transition = 'none'

    })

    modalSingle.addEventListener('touchmove', (e) => {
        if (!singledragging) return;
        singlecurrentY = e.touches[0].clientY
        const deltaY = singlecurrentY - singlestartY

        // Only drag downward
        if (deltaY > 0) {
            modalSingle.style.transform = `translateY(${deltaY}px)`

            // fade background
            const opacity = 0.4 - deltaY / 500
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, ${opacity})`
        }
    })

    modalSingle.addEventListener('touchend', (e) => {
        singledragging = false
        const deltaY = singlecurrentY - singlestartY

        if (deltaY > 100) {
            modalSingle.style.transition = 'transform 0.3s ease-out'
            modalSingle.style.transform = `translateY(100%)`
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0)`
            setTimeout(() => {
                    document.getElementById('single-profile-wrapper').style.display = 'none'
                    document.querySelector('.overlay-single').style.display = 'none'
                    document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0.4)`
                    modalSingle.style.transform = 'translateY(0)'
    
            }, 200)
        } else {
            modalSingle.style.transition = 'transform 0.3s ease-out'
            modalSingle.style.transform = `translateY(0)`
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0.4)`
        }
    })

    document.querySelector('.overlay-single').addEventListener('click', () => {
        modalSingle.style.transition = 'top 0.3s ease-out'
        modalSingle.style.top = '100%'
        document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0)`
        setTimeout(() => {
            document.getElementById('single-profile-wrapper').style.display = 'none'
            document.querySelector('.overlay-single').style.display = 'none'
            document.querySelector('.overlay-single').style.background = `rgba(128, 128, 128, 0.4)`
            modalSingle.style.top = '100%'
        }, 300)
    })

    

</script>    
</body>
</html>