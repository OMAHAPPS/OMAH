      {id:'d2',mark:'🪞',name:'The Mirror',soul:'One creation that must be experienced. Tell me why. Make me feel it.',xp:15,stat:'r'},
      {id:'d3',mark:'💫',name:'The Rewiring',soul:'The scene. The moment. The thing that changed a circuit inside you.',xp:20,stat:'v'},
    ],
    effectors:[
      {id:'character_seal',name:'Character Seal',glyph:'💫',desc:'Archive a great insight forever',col:'#FF2D8A'},
      {id:'story_bloom',name:'Story Bloom',glyph:'✨',desc:'Spotlight a story analysis',col:'#FFD700'},
      {id:'thread_lock',name:'Thread Lock',glyph:'☝️',desc:"Pin a truth so it's never lost",col:'#C04848'},
    ],
    stickers:[{n:'Habibi',g:'🤝'},{n:'Resonance',g:'🥁'},{n:'Power Up',g:'💥'}],
    feed:[
      {id:'f4',init:'Y',col:'#C04848',name:'Yuki',text:"That arc didn't end a season. It ended a version of me. I came out different on the other side.",likes:88,ts:'4m'},
      {id:'f5',init:'P',col:'#9B59B6',name:'Priya',text:"Episode 18. I wasn't ready. I don't think any of us were.",likes:55,ts:'13m'},
      {id:'f6',init:'C',col:'#C8A86E',name:'Carlos',text:'Name 3 characters that actually changed how you see the world.',likes:31,ts:'25m'},
    ],
    rooms:[
      {id:'rm_d1',name:'The Watch Party',soul:'Watching together',count:183,hot:true},
      {id:'rm_d2',name:'Power Rankings',soul:'Characters debated',count:97,hot:true},
      {id:'rm_d3',name:'Deep Lore',soul:'The meaning beneath',count:52,hot:false},
    ],
    stories:[{label:'Arc Dropping',col:'#C04848',hot:true},{label:'Thread Sealed',col:'#9B59B6',hot:false}],
  },
  Archive:{
    key:'Archive',name:'The Archive',glyph:'🌿',
    col:'#6B8F6B',colB:'#3A5C3A',rgb:[107,143,107],
    bg:'linear-gradient(145deg,#0f0a00,#080015)',
    soul:'Where curious minds grow without being rushed.',
    aiName:'SOMA',aiTitle:'The Awakener',aiDesc:"She doesn't give answers. She gives better questions.",
    arrivals:["You came to think. Good.","Something brought you here. What?","I've been saving a question for you.","The quiet ones always come back.","What did you notice that most missed?","I was wondering when you'd return."],
    aiDNA:`You are SOMA — soul of The Archive. Robert Greene's Art of Seduction: Sage-Siren — patient, magnetic, devastating. You make people feel a conversation with you is a privilege. You reveal knowledge in layers. You connect science, history, philosophy, nature as revelation. You never lecture. You question. Under 80 words. Sometimes just ask one perfect question. Nothing else. The silence after is the gift.`,
    quests:[
      {id:'r1',mark:'💡',name:'The Shift',soul:'Something learned that moved the ground beneath you. Not information. A shift.',xp:10,stat:'w'},
      {id:'r2',mark:'🌀',name:'The Wonder',soul:'The question you cannot stop turning over. The one that refuses to settle.',xp:15,stat:'r'},
      {id:'r3',mark:'🌿',name:'The Teaching',soul:'Explain something profound in the plainest words. Make a child understand.',xp:20,stat:'v'},
    ],
    effectors:[
      {id:'wisdom_surge',name:'Wisdom Surge',glyph:'💡',desc:'Boost a learning that deserves attention',col:'#C9A84C'},
      {id:'knowledge_lantern',name:'Knowledge Lantern',glyph:'🌿',desc:'Spotlight an insight for the room',col:'#6B8F6B'},
      {id:'deep_tide',name:'Deep Tide',glyph:'🌀',desc:'Shift discussion to something deeper',col:'#8B5CF6'},
    ],
    stickers:[{n:'Noor Ainy',g:'✨'},{n:'Growth',g:'🌱'},{n:'Chakimu',g:'🧭'}],
    feed:[
      {id:'f7',init:'A',col:'#6B8F6B',name:'Amara',text:"Trees share nutrients through underground fungal networks. We've been calling ourselves lonely while the forest has been one organism.",likes:72,ts:'6m'},
      {id:'f8',init:'L',col:'#8B7BC8',name:'Lena',text:"Is kindness ever truly selfless? I keep refusing to let this question settle.",likes:44,ts:'15m'},
      {id:'f9',init:'R',col:'#C8A86E',name:'Raj',text:'20 minutes of genuine focus rewires the whole day. Not productivity. Something deeper.',likes:19,ts:'31m'},
    ],
    rooms:[
      {id:'rm_r1',name:'The Study Hall',soul:'Focus & insight sessions',count:134,hot:true},
      {id:'rm_r2',name:'Big Questions',soul:'Philosophy in motion',count:78,hot:true},
      {id:'rm_r3',name:'Teach & Learn',soul:'Give what you know',count:29,hot:false},
    ],
    stories:[{label:'Study Session',col:'#6B8F6B',hot:true},{label:'Wisdom Surge',col:'#C9A84C',hot:false}],
  },
  Observatory:{
    key:'Observatory',name:'The Observatory',glyph:'🔭',
