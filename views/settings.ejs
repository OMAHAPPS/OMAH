    ],
    stickers:[{n:'Harakah',g:'⚡'},{n:'The Roar',g:'🦁'},{n:'Clean Sheet',g:'🛡️'}],
    feed:[
      {id:'f1',init:'B',col:'#C8A86E',name:'Bruno',text:'89th minute. I forgot how to breathe for three full seconds. Best goal this decade.',likes:41,ts:'3m'},
      {id:'f2',init:'S',col:'#8B9DC3',name:'Sarah',text:"Best season in memory and the conversation isn't happening. Why are we sleeping on this?",likes:27,ts:'11m'},
      {id:'f3',init:'J',col:'#6B9E6B',name:'Jide',text:'2-1. Said it before the game. The numbers always know before the people do.',likes:14,ts:'22m'},
