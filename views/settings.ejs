const formDP = document.querySelector('.form-dp')
const inputDp = document.getElementById('dp')
const labelDP = document.getElementById('label-dp')
const submitDpBtn = document.getElementById('submit-dp')
const submitActionsCont = document.querySelector('.submit-actions')
const cancelDpBtn = document.querySelector('.cancel-dp')
const errorMessage = document.getElementById('error-display')
const wrapper = document.querySelector('.progress-wrapper')   // display flex - none
const progress = document.querySelector('#overallProgress')
const text = document.querySelector('.progress-text')
const status = document.querySelector('#upload-status')


labelDP.addEventListener('click', () => {

    labelDP.style.display = 'none'                ///// block-none
    submitActionsCont.style.display = 'flex'     //// flex - none

})

cancelDpBtn.addEventListener('click', () => {
   
    labelDP.style.display = 'block'
    submitActionsCont.style.display = 'none'
})


changeHandleBtn.addEventListener('click', () => {

     questBox.style.display = 'none'
     changeBox.style.display = 'none'
     formBox.style.display = 'block'
})

// UPLOAD DP ACTION TO CLOUDFLARE R2

submitDpBtn.addEventListener('click', async (e) => {

    e.preventDefault()

    submitDpBtn.disabled = true
    submitDpBtn.style.backgroundColor = 'grey'
    errorMessage.textContent = 'Please Wait..'

    const fileList = [...inputDp.files]

    const file = fileList[0]
    
    const MAX_SIZE = 3 * 1024 * 1024

    if (!file) {
       labelDP.style.display = 'block'
       submitActionsCont.style.display = 'none'
       errorMessage.textContent = 'No File Selected'
       setTimeout(() => {
        errorMessage.textContent = ''
       }, 3000)

    } else if (file.size > MAX_SIZE) {

       labelDP.style.display = 'block'
       submitActionsCont.style.display = 'none'
       errorMessage.textContent = 'MAX FILE SIZE is 3MB'
       setTimeout(() => {
        errorMessage.textContent = ''
       }, 3000)

    } else {

      // REQUEST UPLOAD URL

    const imageData = { name: file.name, type: file.type }
    const totalImageBytes = file.size
    
    try {

       const dpUploadUrl = await fetch('/gen-dp-upload-url', {
             method: 'POST',
             headers: {
              "Content-Type": "application/json"
             },
             body: JSON.stringify({ file: imageData })
       })
       const uploadUrl = await dpUploadUrl.json()

       if (uploadUrl.error) {

          labelDP.style.display = 'block'
          submitActionsCont.style.display = 'none'
          errorMessage.textContent = 'Authorization Failed..Try Again'
          setTimeout(() => {
             errorMessage.textContent = ''
          }, 3000)

       } else {

        //  Use Successful uploadUrl to post dp

        const wrapper = document.querySelector('.progress-wrapper')   // display flex - none
        const progress = document.querySelector('#overallProgress')
        const text = document.querySelector('.progress-text')
        const status = document.querySelector('#upload-status')

        function uploadDP (uploadUrl, file) {

          return new Promise((resolve, reject) => {

                const xhr = new XMLHttpRequest()

                xhr.open("PUT", uploadUrl.signedUrl, true)

                xhr.setRequestHeader("ContentType", file.type)

                xhr.onprogress = (event) => {

                    if (event.lengthComputable) {

                       wrapper.style.display = 'flex'
                       const percent = Math.round((event.loaded / event.total) * 100)
                       text.textContent = `${percent}%`
                       progress.value = percent

                       if (progress == 100) {
                        status.textContent = 'Complete'
                        status.style.color = '#1ed760'
                        text.style.color = '#1ed760'
                       }
                    }
                }

                xhr.onload = () => {

                  if (xhr.status == 200 ) {

                    resolve(uploadUrl.key)
                  } else {
                    reject(uploadUrl.key)
                  }

                }

                xhr.onerror = () => {
                  reject(uploadUrl.key)
                }

                xhr.send(file)

          })
                  

        }
        
        const imageKey = await uploadDP(uploadUrl, file)

        const completeDpUpdate = await fetch('/update-dp', {
             method: 'PATCH',
             headers: {
              "Content-Type": "application/json"
             },
             body: JSON.stringify({ dpKey: imageKey })
        })

        const updateResp = await completeDpUpdate.json()

        if (updateResp.success == true) {
             
             labelDP.style.display = 'none'
             submitActionsCont.style.display = 'none'
             errorMessage.textContent = 'Success'
             errorMessage.style.color = '#1ed760'
             wrapper.style.display = 'none'
             setTimeout(() => {
               errorMessage.textContent = ''
               window.location.reload()
             }, 3000)

            //  UI UPDATES

                      
        } else {

          console.log(updateResp.error)
           errorMessage.textContent = 'Update Failed'
             errorMessage.style.color = '#1ed760'
             wrapper.style.display = 'none'
             setTimeout(() => {
               errorMessage.textContent = ''
             }, 3000)

            //  UI UPDATES
            labelDP.style.display = 'block'
            submitActionsCont.style.display = 'none'
        }



       }
      
    } catch (error) {

      console.log(error)
      
    }



    }
    
})




        
function validateHandle() {

  if (handleInput.value) {

    if (!handleInput.value.match(/^[a-zA-Z0-9]+( [a-zA-Z0-9]+)*$/)) {

      errorSpan.textContent = 'Only letters and Numbers'
      errorSpan.style.color = 'red'
      submitBtn.style.display = 'none'
       
    } else {
      errorSpan.textContent = 'Ok'
      errorSpan.style.color = 'limegreen'
      submitBtn.style.display = 'block'
         }
  } else {
    submitBtn.style.display = 'none'
    errorSpan.textContent = ''
  }

    
}


