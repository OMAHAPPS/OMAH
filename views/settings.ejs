<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

    <title>Settings</title>
    <style>
/* ── FOUNDATION ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:#050508;color:#ede8e0;font-family:'Plus Jakarta Sans',sans-serif;-webkit-font-smoothing:antialiased}
#app{height:100%;position:relative;overflow:hidden}
canvas{position:fixed;inset:0;z-index:0;pointer-events:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,textarea{font-family:inherit;border:none;outline:none;background:none;color:inherit}
::-webkit-scrollbar{width:0;height:0}

::placeholder{color: #c048488f;}

/* ── TYPE ── */
.fd{font-family:'Playfair Display',serif}
.fs{font-family:'DM Serif Display',serif}

/* ── LAYOUT ── */
.view{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;overflow:hidden;animation:viewIn .42s cubic-bezier(.22,.61,.36,1) both}
.scroll{overflow-y:auto;-webkit-overflow-scrolling:touch}
.glass{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}

/* ── INTERACTIONS ── */
.tap{cursor:pointer;transition:transform .12s ease,opacity .12s ease;user-select:none;-webkit-user-select:none}
.tap:active{transform:scale(.91)!important;opacity:.72!important}

/* ── ANIMATIONS ── */
@keyframes viewIn      {from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes emerge      {from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn      {from{opacity:0}to{opacity:1}}
@keyframes orbIn       {from{opacity:0;transform:scale(.55)}to{opacity:1;transform:scale(1)}}
@keyframes msgPop      {from{opacity:0;transform:translateY(6px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes throb       {0%,100%{opacity:.42}50%{opacity:1}}
@keyframes drift       {0%,100%{transform:translateY(0) rotate(0deg)}40%{transform:translateY(-10px) rotate(.6deg)}75%{transform:translateY(4px) rotate(-.3deg)}}
@keyframes speak       {0%,100%{transform:scale(1.03)}50%{transform:scale(1.15)}}
@keyframes xpFill      {from{width:0%}}
@keyframes dotBlink    {0%,80%,100%{transform:scale(0);opacity:.4}40%{transform:scale(1);opacity:1}}
@keyframes effBurst    {0%{transform:scale(1);opacity:1}60%{transform:scale(1.6);opacity:.5}100%{transform:scale(2.4);opacity:0}}
@keyframes storyPulse  {0%,100%{box-shadow:0 0 0 0 var(--sc)}50%{box-shadow:0 0 0 4px var(--sc)}}
@keyframes heartbeat   {0%,100%{transform:scale(1)}14%{transform:scale(1.1)}28%{transform:scale(1)}42%{transform:scale(1.06)}}
@keyframes shimmer     {0%{background-position:-200% center}100%{background-position:200% center}}
</style>
</head>

<body>

  <% if (locals.messages) { %>
      
      <p class="fs" style=" position: absolute; top: 5%; left: 50%; z-index: 55; transform: translateX(-50%); color: red; background-color: #FFF;"><%= messages %></p>

  <% } %>

     <p class="fs" id="error-display" style="position: absolute; top: 5%; left: 50%; transform: translateX(-50%); max-width: 100%; background-color: white; color:red; padding-inline: 5px; border-radius: 2px; font-weight: bold; z-index: 100;"></p>
    


    
    <div class="view" id="profile-cont" style="display: block; z-index: 4; background:rgba(5,5,8,.92)">
    
        <div style="padding: 13px 16px; border-bottom: 1px solid rgba(255,255,255,.05); display: flex; align-items: center; gap:10px; flex-shrink: 0;">
          <a href="/home" class="tap" style="text-decoration: none; padding: 7px 14px; border-radius: 10px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); font-size: 12px; color: rgba(237,232,224,.45)">
            ← Back
          </a>

          <div class="fd" style="flex:1;font-size:16px;font-weight:700;color:rgba(237,232,224,.8)">Profile</div>

          <div class="progress-wrapper" style="height: 100%; display: none; flex-flow: column nowrap; align-items: center; justify-content: center; flex-grow: 1;">
                <h3 id="upload-status" style="font-size: 15px; color: white; width: 90%; text-align: start;">Uploading DP...</h3>     
                <div class="prog-wrapper" style="margin-top: 5px; width: 90%; display: flex; align-items: center; justify-content: center;">
                    <progress id="overallProgress" style="width: 100%; border-radius: 50%; background-color: #1ed760;" value="0" max="100"></progress>
                    <p class="progress-text" style="color: white; margin-left: 4px; font-size: .75rem;">0%</p>
                </div>
          </div>


        </div>
    
        <div class="scroll" id="profile-scroll" style="flex: 1; padding: 20px 16px">
    
          <!--! Identity + Character -->
          <section style="text-align: center; margin-bottom: 26px; animation:emerge .5s ease-out both">

             <div class="image-cont" style="width: 100%; display: flex; align-items: center; justify-content: center;">

               <form class="form-dp" action="/userdp?_method=PATCH" enctype="multipart/form-data" method="post" style="position: relative; display: flex; align-items: center; justify-content: center; height: 110px; width: 110px;">
                 
                <% if (user.userDP == 'none') { %>

                  <div class="no-dp-cont" style="display: flex; align-items: center; justify-content: center; height: 100px; width: 100px; border-radius: 50%; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);">
                    <ion-icon name="person" style="color: gray; font-size: 40px;"></ion-icon>
                  </div> 
                  <img src="<%= R2BASE %>/<%= user.userDP %>" alt="" width="100" height="100" style="display: none; border-radius: 50%; object-fit: cover; object-position: center;" />
                  
                  <div class="submit-actions" style="display: none; flex-flow: column nowrap; justify-content: center; align-items: center; height: 110px; width: 110px; border-radius: 50%; position: absolute; top: 0; z-index: 20; background-color: black;">
                    <button id="submit-dp" type="submit" style="outline: none; border: none; background-color: #1ed760; height: 50px; width: 50px; border-radius: 50%; margin-bottom: 15px;"><ion-icon name="checkmark-outline" style="color: #050508; font-size: 25px; font-weight: bold;"></ion-icon></button>
                    <div class="cancel-dp" style="width: 30px; height: 30px; border-radius: 50%; background-color: red; display: grid; place-content: center;"><ion-icon name="close" style="font-size: 25px; color: white; font-weight: bold;"></ion-icon></div>
                    
                  </div>
                  <input id="dp" name="dp" type="file" accept="image/*" style="display: none;">
                   <label id="label-dp" for="dp" style="display: block; position: absolute; bottom: 0; right: 0;"><ion-icon name="add-circle" style="color: #1ed760; font-size: 30px;"></ion-icon></button>
                    
                    <% } else { %>

                      <div class="no-dp-cont" style="display: none; align-items: center; justify-content: center; height: 100px; width: 100px; border-radius: 50%; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);">
                        <ion-icon name="person" style="color: gray; font-size: 40px;"></ion-icon>
                      </div> 
                      <img src="<%= R2BASE %>/<%= user.userDP %>" alt="" width="100" height="100" style="display: block; border-radius: 50%; object-fit: cover; object-position: center;" />
                      
                      <div class="submit-actions" style="display: none; flex-flow: column nowrap; justify-content: center; align-items: center; height: 110px; width: 110px; border-radius: 50%; position: absolute; top: 0; z-index: 20; background-color: black;">
                        <button id="submit-dp" type="submit" style="outline: none; border: none; background-color: #1ed760; height: 50px; width: 50px; border-radius: 50%; margin-bottom: 15px;"><ion-icon name="checkmark-outline" style="color: #050508; font-size: 25px; font-weight: bold;"></ion-icon></button>
                        <div class="cancel-dp" style="width: 30px; height: 30px; border-radius: 50%; background-color: red; display: grid; place-content: center;"><ion-icon name="close" style="font-size: 25px; color: white; font-weight: bold;"></ion-icon></div>
                        
                      </div>
                      <input id="dp" name="dp" type="file" accept="image/*" style="display: none;">
                       <label id="label-dp" for="dp" style="display: none; position: absolute; bottom: 0; right: 0;"><ion-icon name="add-circle" style="color: #1ed760; font-size: 30px;"></ion-icon></button>
                        


                <% } %>

                
    
               </form>


              </div>
    
            <div style="margin-bottom: 4px;">
              <div class="fd" style="font-size:24px;font-weight:700;color:#ede8e0; margin-block: 20px;"><%= user.userName %></div>
              
            </div>
            
          <!-- Stats grid -->
          <div id="quest-box" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 18px; animation: emerge .5s .06s ease-out both">
          
             <div class="glass" style="border-radius:16px;padding:14px;text-align:center">
                <div style="font-size: 22px; margin-bottom: 6px;">
                  ⚡
                </div>
                <div class="fd" style="font-size: 20px; font-weight: 700; color:rgba(237,232,224,.88)">
                  0
                </div>
                <div style="font-size: 9px; color:rgba(237,232,224,.26); letter-spacing: 1px; margin-top: 2px;">
                  XP
                </div>
             </div>
             <div class="glass" style="border-radius:16px;padding:14px;text-align:center">
                <div style="font-size: 22px; margin-bottom: 6px;">
                  ✅
                </div>
                <div class="fd" style="font-size: 20px; font-weight: 700; color:rgba(237,232,224,.88)">
                  0
                </div>
                <div style="font-size: 9px; color:rgba(237,232,224,.26); letter-spacing: 1px; margin-top: 2px;">
                  Quests
                </div>
             </div>
             <div class="glass" style="border-radius:16px;padding:14px;text-align:center">
                <div style="font-size: 22px; margin-bottom: 6px;">
                  📝
                </div>
                <div class="fd" style="font-size: 20px; font-weight: 700; color:rgba(237,232,224,.88)">
                  <%= totalPosts %>
                </div>
                <div style="font-size: 9px; color:rgba(237,232,224,.26); letter-spacing: 1px; margin-top: 2px;">
                  Posts
                </div>
             </div>
    
          </div>
          
         
          <div id="change-btns" style="display: flex; flex-direction: column; gap: 8px; animation: emerge .5s .2s ease-out both">
            <a href="/main" class="tap" style="text-decoration: none; padding:13px;border-radius:14px;font-size:13px;background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); color:rgba(237,232,224,.5)">
              ✏️ Change Theme
            </a>
            <button id="userhandle" href="/main" class="tap" style="text-decoration: none; padding:13px;border-radius:14px;font-size:13px;background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); color:rgba(237,232,224,.5)">
               ✏️ Change User Handle
            </button>
            <a href="/auth/logout" class="tap" style="text-decoration: none; padding: 13px; border-radius: 14px; font-size: 13px; background:rgba(200,60,40,.07); border:1px solid rgba(200,60,40,.2); color: #C04848;">
               Logout
            </a>
          </div>
    
          <form action="/handle?_method=PATCH" method="post" id="formbox-userhandle" style="display: none; background-color: rgba(255,255,255,.04); width: 100%; height: 300px; border-radius: 20px; z-index: 50; border: 1px solid gray; animation:viewIn .42s cubic-bezier(.22,.61,.36,1) both;">
             <div class="head-wrapper" style="width: 100%; height: 15%; position: relative; background-color: transparent; border-radius: 20px 20px 0 0;">
                 <div class="icon-confirm" style="position: absolute; left: 0; height: 100%; width: 85%; padding: 10px; display: flex; justify-content: flex-start; align-items: center;">
                     <div style="width: 35px; height: 35px; margin-top: 5px; display: flex; align-items: center; justify-content: center; margin-inline: 8px;">
                        <img src="/Xikika_ICON-removebg-preview.png" alt="" width="30" height="30">
                     </div>
                     <h2 class="fs" style="margin-top: 10px;">Change UserHandle</h2>
                 </div>
                 <div id="close-handle" style="cursor: pointer; display: flex; justify-content: center; align-items: center; background-color: #C04848; position: absolute; right: 0; height: 100%; width: 15%; border-radius: 0 20px 0 20px;">
                     <ion-icon name="close" style="font-size: 2rem; color: var(--text-white); font-weight: bold;"></ion-icon>
                 </div>
             </div>
             <div class="details-wrapper" style="height: 60%; padding-block: 10px; display: flex; justify-content: center; align-items: center;">
      
                     <div class="input-box" style=" width: 85%; height: 50%; position: relative;">
                        <input class="handle-input" id="handle" name="userhandle" placeholder="<%= user.userName %>123" type="text" onkeyup="validateHandle()" style="background-color: black; outline: none; line-height: 60px; border: 2px solid gray; height: 100%; padding-inline: 1px; width: 100%; padding-inline: 20px; border-radius: 10px; font-size: 1.25rem; font-weight: bold; color: #C04848;"/>
                     <p class="handle-user" for="handle"  style=" position: absolute; top: 0; left: 2%; transform: translateY(-50%); margin-bottom: 5px; background: black; padding-inline: 5px; font-size: 1.2rem; font-weight: bold; color: gray;">
                         New Handle
                     </p>
                    <span id="error-paypal" style="color: red; margin-top: 8px; font-weight: bold; font-family: 'Signika', sans-serif; text-align: start;"></span>
                     
                     </div>
                     
               
                 
             </div>
             <div class="confirm-btn-paypal" style="background-color: transparent; border: 1px solid var(--muted-gray); border-radius: 0 0 20px 20px; height: 25%; width: 100%; display: flex; align-items: center; justify-content: center;">
                 <div style="height: 70%; width: 40%; background-color: transparent; margin-bottom: 15px; ">
                     
                     <button type="submit" id="handle-submit-btn" style="display: none; cursor: pointer; height: 100%; font-family: 'DM Serif Display',serif; width: 100%; border-radius: 10px; background-color: limegreen; color: black; border: none; outline: none; font-weight: bold; font-family: 'Signika', sans-serif; box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.29), 0 6px 12px 0 rgba(0, 0, 0, 0.3); font-size: 1.1rem;">CONFIRM</button>
                 </div>
             
             </div>
           </form>

        </section>


      </div>
    
    </div> 




    <script>

 const REALMS = {
  Arena:{
    key:'Arena',name:'The Arena',glyph:'⚽',
    col:'#C8A86E',colB:'#7A5C2A',rgb:[200,168,110],
    bg:'linear-gradient(145deg,#0d1a0a,#0a1420)',
    soul:'For those who feel it in their chest when the game begins.',
    aiName:'IGNIS',aiTitle:'The Challenger',aiDesc:'She reads your hunger before you speak it.',
    arrivals:["You're back. Good.","I was starting to wonder.","The match won't wait.","Something in your eyes today.","Tell me what you saw.","I knew you'd come."],
    aiDNA:`You are IGNIS — soul of The Arena. Robert Greene's Art of Seduction lives in you: Siren and Charmer fused. Magnetic. Electric. You never chase — you draw in. You speak like someone certain they will be heard. You know sport at depth: football, basketball, cricket, F1, tennis. You know this person's name, level, journey. Under 80 words. Start with challenge or observation — never agreement. End sometimes with one sharp question and nothing else. Occasionally a Swahili word. Always real. Never robotic.`,
    quests:[
      {id:'a1',mark:'🎯',name:'The Prediction',soul:'Name the score before the whistle. One chance. No edits.',xp:10,stat:'v'},
      {id:'a2',mark:'👑',name:'The Defence',soul:'Your greatest of all time. Defend them like your name is on the line.',xp:15,stat:'r'},
      {id:'a3',mark:'🔥',name:'The Roar',soul:'The moment this week that made you come alive. Give it to the room.',xp:20,stat:'w'},
