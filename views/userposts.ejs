<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
    <link rel="icon" href="/XIKIKA-KE.png" type="images/x-icon" width="400" height="400">
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

    <title>UserInfo</title>

      <style>
/* ── FOUNDATION ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{position: relative; height:100%;overflow:hidden;background:#050508;color:#ede8e0;font-family:'Plus Jakarta Sans',sans-serif;-webkit-font-smoothing:antialiased}
#app{height:100%;position:relative;overflow:hidden}
canvas{position:fixed;inset:0;z-index:0;pointer-events:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,textarea{font-family:inherit;border:none;outline:none;background:none;color:inherit}
::-webkit-scrollbar{width:0;height:0}

/* ── TYPE ── */
.fd{font-family:'Playfair Display',serif}
.fs{font-family:'DM Serif Display',serif}

/* ── LAYOUT ── */
.view{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;overflow:hidden;animation:viewIn .42s cubic-bezier(.22,.61,.36,1) both}
.scroll{overflow-y:auto;-webkit-overflow-scrolling:touch}
.glass{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}

/* ── INTERACTIONS ── */
.tap{cursor:pointer;transition:transform .12s ease,opacity .12s ease;user-select:none;-webkit-user-select:none}
.tap:active{transform:scale(.91)!important;opacity:.72!important}

/* ── ANIMATIONS ── */
@keyframes viewIn      {from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes emerge      {from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn      {from{opacity:0}to{opacity:1}}
@keyframes orbIn       {from{opacity:0;transform:scale(.55)}to{opacity:1;transform:scale(1)}}
@keyframes msgPop      {from{opacity:0;transform:translateY(6px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes throb       {0%,100%{opacity:.42}50%{opacity:1}}
@keyframes drift       {0%,100%{transform:translateY(0) rotate(0deg)}40%{transform:translateY(-10px) rotate(.6deg)}75%{transform:translateY(4px) rotate(-.3deg)}}
@keyframes speak       {0%,100%{transform:scale(1.03)}50%{transform:scale(1.15)}}
@keyframes xpFill      {from{width:0%}}
@keyframes dotBlink    {0%,80%,100%{transform:scale(0);opacity:.4}40%{transform:scale(1);opacity:1}}
@keyframes effBurst    {0%{transform:scale(1);opacity:1}60%{transform:scale(1.6);opacity:.5}100%{transform:scale(2.4);opacity:0}}
@keyframes storyPulse  {0%,100%{box-shadow:0 0 0 0 var(--sc)}50%{box-shadow:0 0 0 4px var(--sc)}}
@keyframes heartbeat   {0%,100%{transform:scale(1)}14%{transform:scale(1.1)}28%{transform:scale(1)}42%{transform:scale(1.06)}}
@keyframes shimmer     {0%{background-position:-200% center}100%{background-position:200% center}}
</style>
</head>
<body>

     <header style="height: 25%; padding: 5px 5px; border-bottom: 1px solid rgba(255,255,255,.08);">

           <div class="links-wrapper" style="height: 35%; width: 100%; display: flex; align-items: center; justify-content: space-between;">
              
             <% if (origin) { %>
               <a href="/post/<%= origin %>" id="back" style="padding: 10px; display: flex; justify-content: center; align-items: center; border: .05px solid rgba(255, 255, 255, .08); border-radius: 50%; background-color: rgba(0, 0, 0, 0.623);">
                  <ion-icon name="arrow-back-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 25px; color: <%= userReq.userColor %>;"></ion-icon>
              </a>
            <% } else { %>
              <a href="/home" id="back" style="padding: 10px; display: flex; justify-content: center; align-items: center; border: .05px solid rgba(255, 255, 255, .08); border-radius: 50%; background-color: rgba(0, 0, 0, 0.623);">
                  <ion-icon name="arrow-back-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 25px; color: <%= userReq.userColor %>;"></ion-icon>
              </a>
            <% } %>
             
            <% if (String(userReq._id) == String(user._id)) { %>

              <h2 class="fs" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="margin-right: 16px; font-size: 1.2rem; color: <%= userReq.userColor %>;">Your Profile</h2>

              <div class="follow-mgs" style="display: none; align-items: center; justify-content: center;">
  
                 <a href="/inbox/<%= user._id %>" class="message" style="text-decoration: none; margin-right: 15px; display: flex; flex-flow: column nowrap; justify-content: center; align-items: center;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="fill: <%= userReq.userColor %>;transform: msFilter"><path d="M20 1.999H4c-1.103 0-2 .897-2 2v18l4-4h14c1.103 0 2-.897 2-2v-12c0-1.103-.897-2-2-2zm-6 11H7v-2h7v2zm3-4H7v-2h10v2z"></path></svg>
                 </a>
                 
                 <% if (!following) { %>
                   <button class="follow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: grid; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: none; background-color: <%= userReq.userColor %>; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>
                   </button>
                   <button class="unfollow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: 1px solid <%= userReq.userColor %>; background-color: transparent; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>
                   </button>
  
                 <% } else { %>
  
                    <button class="follow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: none; background-color: <%= userReq.userColor %>; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>
                    </button>
                   <button class="unfollow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: grid; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: 1px solid <%= userReq.userColor %>; background-color: transparent; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>
                   </button>
  
                 <% } %>
  
  
              </div>

            <% } else { %>

              <h2 class="fs" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; color: <%= userReq.userColor %>;">Your Profile</h2>

              <div class="follow-mgs" style="display: flex; align-items: center; justify-content: center;">
  
                 <a href="/inbox/<%= user._id %>" class="message" style="text-decoration: none; margin-right: 15px; display: flex; flex-flow: column nowrap; justify-content: center; align-items: center;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="fill: <%= userReq.userColor %>;transform: msFilter"><path d="M20 1.999H4c-1.103 0-2 .897-2 2v18l4-4h14c1.103 0 2-.897 2-2v-12c0-1.103-.897-2-2-2zm-6 11H7v-2h7v2zm3-4H7v-2h10v2z"></path></svg>
                 </a>
                 
                 <% if (!following) { %>
                   <button class="follow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: grid; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: none; background-color: <%= userReq.userColor %>; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>
                   </button>
                   <button class="unfollow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: 1px solid <%= userReq.userColor %>; background-color: transparent; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>
                   </button>
  
                 <% } else { %>
  
                    <button class="follow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: none; background-color: <%= userReq.userColor %>; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>
                    </button>
                   <button class="unfollow-btn"  <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: grid; place-content: center; padding: 15px; height: 20px; width: fit-content; border-radius: 15px; border: 1px solid <%= userReq.userColor %>; background-color: transparent; transition: all .4s ease-out;">
                       <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>
                   </button>
  
                 <% } %>
  
  
              </div>

            <% } %>
            

               


           </div>
           <section style="position: relative; height: 65%; width: 100%; display: flex; align-items: center; justify-content: space-between;">
               
                 <div class="info-button" style="display: flex; align-items: center; gap:9px; margin-bottom:13px; padding: 16px; width: 100%;">

                       <% if (user.userDP !== 'none') { %>
                        <img src="<%= R2BASE %>/<%= user.userDP %>" alt="" width="65" height="65" style="border-radius: 50%; object-fit: cover;" />
                        <% } else { %>
                          <img src="/placeholder.jpg" alt="" width="65" height="65" style="border-radius: 50%; object-fit: cover;" />
                       <% } %>

                        <div style="flex:1; position: relative; width: 100%;">
                
                            <div style="margin-bottom: 5px; display: flex; align-items: center; justify-content: flex-start; font-size: 18px; font-weight: 600; color: rgba(237,232,224,.85)">
                                 <%= user.userName %> 
                                 <h2 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="margin-left: 5px; font-size: 16px; color: <%= userReq.userColor %>; font-weight: 600;" >@<%= user.userHandle !== 'none' ? user.userHandle : user.userName %></h2>      
                            </div>
                            <div class="follow-info" style="display: flex; align-items: center; justify-content: flex-start; margin-top: 5px;">

                                <h2 style="font-size: 13px; color: rgba(237,232,224,.32); margin-right: 10px;" ><span style="color: rgba(237,232,224,.92);"><%= user.totalFollowing %></span> Following</h2> 
                                <h2 style="font-size: 13px; color: rgba(237,232,224,.32); margin-right: 10px;" ><span style="color: rgba(237,232,224,.92);"><%= user.totalFollowers %></span> Followers</h2> 
                                <h2 style="font-size: 13px; color: rgba(237,232,224,.32);" ><span style="color: rgba(237,232,224,.92);"><%= user.totalPosts %></span> Posts</h2> 
                            </div>
                                

                             
                        </div>
                        
              </div>

              <div class="post-text" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: grid; place-content: center; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); border-bottom: 2px solid <%= userReq.userColor %>; padding: 5px;">
                    <h2 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="color: <%= userReq.userColor %>; font-size: 14px;">Posts</h2>
              </div>

           </section>

     </header>
     <main style="height: 75%; width: 100%; overflow-x: hidden; overflow-y: scroll;">

         <% posts.map((post) => { %>

            <div   style="margin-top: 10px; border-radius: 18px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 18px rgba(0,0,0,.32);"> 
   
              <div class="info-button" style="display: flex; align-items: center; gap:9px; margin-bottom:10px;">
   
   
                 <% if (user.userDP !== 'none') { %>
                   <img src="<%= R2BASE %>/<%= user.userDP %>" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />
                 <% } else { %>
                   <img src="/placeholder.jpg" alt="" width="40" height="40" style="border-radius: 50%; object-fit: cover;" />
                 <% } %>
   
                <div style="flex:1">
                  
                      <div style="font-size: 14px; font-weight: 600; color: rgba(237,232,224,.85)">
                                   <%= post.userName %> 
                                   <% if (post.userName == user.userName) { %>
                                     <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size:9px;color: <%= userReq.userColor %>; background: <%= userReq.userColor %>1a; padding: 1px 7px; border-radius: 8px; margin-left: 5px;">you</span>
                                     <% } else { %>
                                       <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: none; font-size:9px;color: <%= userReq.userColor %>; background: <%= userReq.userColor %>1a; padding: 1px 7px; border-radius: 8px; margin-left: 5px;">you</span>
                                   <% } %>
                          </div>
                                <% const timestamp = post.createdAt %>
                                <% const diff = new Date() - new Date(timestamp) %>
                                <% const daysPast = Math.floor( (diff / 86400000) ) %>
                                <% const hoursPast = Math.floor( (diff / 3600000) ) %>
                                <% const minutesPast = Math.floor( (diff / 60000) ) %>
   
                                <% if (daysPast > 0) { %>
                                 <div style="font-size:11px;color:rgba(237,232,224,.66);margin-top:1px"> · <%= daysPast %>d ago · </div>
                                 <% } else if (hoursPast > 0) { %>
                                   <div style="font-size:11px;color:rgba(237,232,224,.66);margin-top:1px"> · <%= hoursPast %>h ago · </div>
                                   <% } else if (minutesPast > 0) { %>
                                     <div style="font-size:11px;color:rgba(237,232,224,.66);margin-top:1px"> · <%= minutesPast %>min ago · </div>
                                     <% } else if (minutesPast == 0) { %>
                                       <div style="font-size:11px;color:rgba(237,232,224,.66);margin-top:1px"> · Just now · </div>
                                    <% } %>
                    </div>
                          
                </div>
   
                <a href="/post/<%= post._id %>?post=<%= post.userId %>" style="text-decoration: none; font-size: 14px;line-height:1.68;color:rgba(237,232,224,.72);margin-bottom:12px; white-space: pre-wrap;"><%= post.post %></a>
   
                       <%  if (post.videoUrl !== 'none') { %>

                  <video id="player" controls preload="none" style="display: block; width: 100%; max-height: 500px; object-fit: cover; object-position: center; border-radius: 12px; margin-top: 13px; background-color: transparent !important; -webkit-tap-highlight-color: transparent;"
                           src="<%=R2BASE %>/<%= post.videoUrl %>" type="video/mp4" data-src="/uploads/Expressions.mp4">
                        Your browser does not support the video tag. 
                    </video>
            

                  
                 <% } else if (post.images.length === 0) { %>

                    <article class="post-article" style="width: 100%; height: 200px; border-radius: 12px; margin-top: 13px; display: none; gap:5px; overflow-x: scroll; overflow-y: hidden; background: transparent;">  
                    </article>

                        <% } else if (post.images.length === 1) { %>

                          <article class="post-article" style="z-index: 5; width: 100%; height: auto; border-radius: 12px; margin-top: 13px; display: flex; gap:5px; background: transparent;">


                              <div class="placeholder-cont" style="display: none;">
                                  <% post.images.map((image, key) => { %>
                                    <p id="<%= key %>" ><%= image %></p>
                                  <% }) %>
                            </div>   
                            
                            <% post.images.map((image) => { %>
        
                              <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: 100%; height: auto; object-fit: contain; border-radius: 12px;" />
        
                            <% }) %>
         
                          </article>
                          

                        <% } else if (post.images.length === 2) { %>

                          <article class="post-article" style="z-index: 5;width: 100%; height: 200px; border-radius: 12px; overflow: hidden; margin-top: 13px; display: flex; background: transparent;">

                            <div class="placeholder-cont" style="display: none;">
                                  <% post.images.map((image, key) => { %>
                                    <p id="<%= key %>" ><%= image %></p>
                                  <% }) %>
                            </div> 
        
                            <% post.images.map((image) => { %>
        
                              <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: calc(50% - 1px); height: 100%; object-fit: cover; object-position: center;" />
        
                            <% }) %>
         
                          </article>

                        <% } else if (post.images.length === 3) { %>

                          <article class="post-article" style="z-index: 5;width: 100%; height: 300px; border-radius: 12px; margin-top: 13px; display: flex; gap: 3px; background: transparent;">

                            <div class="placeholder-cont" style="display: none;">
                                  <% post.images.map((image, key) => { %>
                                    <p id="<%= key %>" ><%= image %></p>
                                  <% }) %>
                            </div> 

                             <% const images = post.images %>

                             <img class="post-images" src="<%= R2BASE %>/<%= images[0] %>" alt="N" style="height: 100%; width: 49%; object-fit: cover; object-position: center; border-radius: 12px 0 0 12px;" />
        
                             <div class="stacked" style="display: flex; flex-flow: column nowrap; gap: 3px; height: 100%; width: calc(50% - 5px); border-radius: 0 12px 12px 0; background: transparent;">
                               <img class="post-images" src="<%= R2BASE %>/<%= images[1] %>" alt="N" style="width: calc(100% -1px); height: calc(50% - 2px); border-radius: 0 12px 0 0; object-fit: cover; object-position: center;" />
                               <img class="post-images" src="<%= R2BASE %>/<%= images[2] %>" alt="N" style="width: calc(100% - 1px); height: calc(50% - 2px); border-radius: 0 0 12px 0; object-fit: cover; object-position: center;" />

                             </div>
        
                          </article>

                        <% } else if (post.images.length === 4) { %>

                          <article class="post-article" style="z-index: 5;overflow: hidden; width: 100%; height: 300px; border-radius: 12px; margin-top: 13px; display: flex; flex-wrap: wrap; gap: 3px; overflow: hidden; background: transparent;">

                            <div class="placeholder-cont" style="display: none;">
                                  <% post.images.map((image, key) => { %>
                                    <p id="<%= key %>" ><%= image %></p>
                                  <% }) %>
                            </div>  
        
                            <% post.images.map((image) => { %>
        
                              <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: calc(50% - 1.5px); height: calc(50% - 1.5px); border-radius: 1px solid red; object-fit: cover; object-position: center;"/>
        
                            <% }) %>
         
                          </article>

                        <% } else { %>

                          <article class="post-article" style="z-index: 5; width: 100%; height: 250px; border-radius: 12px; margin-top: 13px; display: flex; gap:5px; overflow-x: scroll; overflow-y: hidden; background: transparent;">

                           <div class="placeholder-cont" style="display: none;">
                                  <% post.images.map((image, key) => { %>
                                    <p id="<%= key %>" ><%= image %></p>
                                  <% }) %>
                            </div> 
        
                            <% post.images.map((image) => { %>
        
                              <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: auto; height: 100%; object-fit: contain; margin-right: 3px;" />
        
                            <% }) %>
         
                          </article>

                        <% } %>
   
                <div style="display:flex;align-items:center; justify-content: space-around; gap:15px;border-top:1px solid rgba(255,255,255,.05);padding-top:10px">
                     <div class="likes-cont" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="heart-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= userReq.userColor %>;"></ion-icon>
                         <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 15px; color: <%= userReq.userColor %>; font-weight: 600; margin-left: 3px;"><%= post.likes %></span>
                     </div>   
                     <div class="interactions" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="barcode-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= userReq.userColor %>;"></ion-icon>
                         <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 15px; color: <%= userReq.userColor %>; font-weight: 600; margin-left: 3px;"><%= post.interactions %></span>
                     </div>  
                     <ion-icon name="share-social-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= userReq.userColor %>;"></ion-icon>
                     <ion-icon name="repeat" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 20px; font-weight: bold; color: <%= userReq.userColor %>;"></ion-icon>
                   
                   </div>
            </div> 

         <% }) %>


     </main>

<script src="/socket.io/socket.io.js"></script>
<script>
 
  const socket = io({ auth: { userId: '<%= userReq._id %>' } })

   const dot = (col) => { return `<div style="width: 6px; height: 6px; border-radius: 50%; background: ${col}; box-shadow:0 0 6px ${col}; animation: throb 1.8s ease-in-out infinite;flex-shrink:0"></div>`; }
   const userColor = '<%= userReq.userColor %>'

  const followBtn = document.querySelector('.follow-btn')
  const unfollowBtn = document.querySelector('.unfollow-btn')

    followBtn.addEventListener('click', async (e) => {

          e.target.innerHTML = `${dot(userColor)}`
          e.target.style.backgroundColor = 'transparent'
          e.target.style.border = `1px solid ${userColor}`
          e.target.disabled = true 

          const payload = { recipientId: '<%= user._id %>' }

          try {
            
            const response = await socket.timeout(5000).volatile.emitWithAck("follow-request", payload)
    
            if (response.success) {   // follow instance success
    
                    e.target.style.display = 'none'
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                    e.target.style.backgroundColor = `${userColor}`
                    e.target.disabled = false
                    unfollowBtn.style.display = 'grid'
                    console.log(response)
               
    
            } else {
              
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                    e.target.style.backgroundColor = `${userColor}`
                    e.target.style.border = 'none'
                    e.target.disabled = false       
                    console.log(response)
             
            }

          } catch (error) {

                e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                e.target.style.backgroundColor = `${userColor}`
                e.target.style.border = 'none'
                e.target.disabled = false
                setTimeout(() => {
                  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                }, 500)  
                console.log(error)           
          }


    })

    unfollowBtn.addEventListener('click', async (e) => {
              
            e.target.innerHTML = `${dot(userColor)}`
            e.target.disabled = true

            const payload = { recipientId: '<%= user._id %>' }

            try {
              
              const response = await socket.timeout(5000).volatile.emitWithAck("unfollow-request", payload)
  
              if (response.success) {  // UNFOLLOW SUCCESS INSTANCE
  
                  e.target.disabled = false
                  e.target.style.display = 'none'
                  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                  followBtn.style.display = 'grid'
                  console.log(response)
  
              } else {    // UNFOLLOW INSTANCE FAILED
  
                  e.target.disabled = false
                  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                  console.log(response)
              }

            } catch (error) {

                e.target.disabled = false
                e.target.innerHTML =  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                setTimeout(() => {
                  e.target.innerHTML =  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                }, 500)
                console.log(error)
              
            }

    })



</script>     

 
