               <a id="link-to-post" href="" class="stop-fetch" <% /* eslint-disable-next-line css-propertyvalueexpected */ %>  style="text-decoration: none; display: grid; place-content: center; padding: 15px; height: 40px; width: fit-content; border-radius: 20px; border: 1px solid <%= user.userColor %>; background-color: transparent;">
