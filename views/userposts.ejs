<script src="/socket.io/socket.io.js"></script>
<script>
 
  const socket = io({ auth: { userId: '<%= userReq._id %>' } })

   const dot = (col) => { return `<div style="width: 6px; height: 6px; border-radius: 50%; background: ${col}; box-shadow:0 0 6px ${col}; animation: throb 1.8s ease-in-out infinite;flex-shrink:0"></div>`; }
   const userColor = '<%= userReq.userColor %>'

  document.querySelectorAll('.likes-cont-event').forEach((btn) => {
  
               let debounceTimer = null

               btn.addEventListener('click', (e) => {
    
                    e.preventDefault()
    
                    const currentActiveState = btn.dataset.liked === 'true' 
                    const likeIcon = btn.querySelector('.like')
                    const unlikeIcon = btn.querySelector('.unlike')
                    const h3Span = btn.querySelector('.like-h3')
                    const postId = btn.querySelector('.postId-span').textContent
    
                    const newLikedState = !currentActiveState
                 
                    btn.dataset.liked = (newLikedState).toString()
    
                    if (newLikedState) {
      
                       likeIcon.style.display = 'block'
                       likeIcon.style.scale = '1.2'
                       unlikeIcon.style.display = 'none'
      
      
                    } else {
                       likeIcon.style.display = 'none'
                       unlikeIcon.style.display = 'block'
                       unlikeIcon.style.scale ='1.2'
     
                    }
   
                     clearTimeout(debounceTimer)
    
                    const updateDB = async (postId, btn) => {

                        const currentDataSet = btn.dataset.liked
                        const payload = { postId: postId, dataset: currentDataSet }

                    try {
                      
                      const response = await socket.timeout(5000).volatile.emitWithAck("update-likes", payload)
           
                      if (response.success) {
                        // update Success Instance
                      if (response.UIStatus == 'like') {
  
                         h3Span.textContent = response.newLikesCount
                         likeIcon.style.display = 'block'
                         likeIcon.style.scale = '1'
                         unlikeIcon.style.display = 'none'
                         console.log(response)
                       } else {
                         h3Span.textContent = response.newLikesCount
                         likeIcon.style.display = 'none'
                         unlikeIcon.style.display = 'block'
                         unlikeIcon.style.scale = '1'
                         console.log('Successfully unliked the post on all fronts')
                         console.log(response)
                       }
                       } else {
                        // failure instance
                         likeIcon.style.display = 'none'
                         unlikeIcon.style.display = 'block'
                         unlikeIcon.style.scale = '1'
                         console.log('Likes did not comeThrough')
                         console.log(response.error)
                       }

                    } catch (error) {

                         likeIcon.style.display = 'none'
                         unlikeIcon.style.display = 'block'
                         unlikeIcon.style.scale = '1'
                         errorMessage.textContent = 'Connection Failure'
                         setTimeout(() => {
                          errorMessage.textContent = ''
                         }, 1500)
                      
                    }    



                    } 

                 debounceTimer = setTimeout(() => {
      
                   updateDB(postId, btn)
     
                 }, 500)
    
              })
  })
  

  const followBtn = document.querySelector('.follow-btn')
  const unfollowBtn = document.querySelector('.unfollow-btn')
  const addNotifyBtn = document.querySelector('.notifyOff')
  const removeNotifyBtn = document.querySelector('.notifyOn')

  followBtn.addEventListener('click', async (e) => {

          e.target.innerHTML = `${dot(userColor)}`
          e.target.style.backgroundColor = 'transparent'
          e.target.style.border = `1px solid ${userColor}`
          e.target.disabled = true 

          const payload = { recipientId: '<%= user._id %>' }

          try {
            
            const response = await socket.timeout(5000).volatile.emitWithAck("follow-request", payload)
    
            if (response.success) {   // follow instance success
    
                    e.target.style.display = 'none'
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                    e.target.style.backgroundColor = `${userColor}`
                    e.target.disabled = false
                    unfollowBtn.style.display = 'grid'
                    console.log(response)
               
    
            } else {
              
                    e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                    e.target.style.backgroundColor = `${userColor}`
                    e.target.style.border = 'none'
                    e.target.disabled = false       
                    console.log(response)
             
            }

          } catch (error) {

                e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                e.target.style.backgroundColor = `${userColor}`
                e.target.style.border = 'none'
                e.target.disabled = false
                setTimeout(() => {
                  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: black; font-size: .75rem;">Follow</h4>`
                }, 500)  
                console.log(error)           
          }


    })

  unfollowBtn.addEventListener('click', async (e) => {
              
            e.target.innerHTML = `${dot(userColor)}`
            e.target.disabled = true

            const payload = { recipientId: '<%= user._id %>' }

            try {
              
              const response = await socket.timeout(5000).volatile.emitWithAck("unfollow-request", payload)
  
              if (response.success) {  // UNFOLLOW SUCCESS INSTANCE
  
                  e.target.disabled = false
                  e.target.style.display = 'none'
                  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                  followBtn.style.display = 'grid'
                  console.log(response)
  
              } else {    // UNFOLLOW INSTANCE FAILED
  
                  e.target.disabled = false
                  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                  console.log(response)
              }

            } catch (error) {

                e.target.disabled = false
                e.target.innerHTML =  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: red; font-size: .75rem;">Failed</h4>`
                setTimeout(() => {
                  e.target.innerHTML =  e.target.innerHTML = `<h4 <% /* eslint-disable-next-line css-propertyvaluexpected */ %> style="pointer-events: none; color: <%= userReq.userColor %>; font-size: .75rem;">Following</h4>`
                }, 500)
                console.log(error)
              
            }

    })

  addNotifyBtn.addEventListener('click', async (e) => {
        
        e.target.innerHTML = `${dot(userColor)}`
        e.target.style.backgroundColor = 'transparent'
        e.target.disabled = true
        
        const payload = { recipientId: '<%= user._id %>' }

        try {

          const response = await socket.timeout(5000).volatile.emitWithAck('addNotification', payload)

          if (response.success) {

            e.target.style.display = 'none'
            e.target.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; fill: <%= userReq.userColor %>;transform: msFilter"><path d="M20.345 18.931A.993.993 0 0 0 21 18v-1a.996.996 0 0 0-.293-.707L19 14.586V10c0-3.217-2.185-5.927-5.145-6.742C13.562 2.52 12.846 2 12 2s-1.562.52-1.855 1.258c-1.323.364-2.463 1.128-3.346 2.127L3.707 2.293 2.293 3.707l18 18 1.414-1.414-1.362-1.362zM12 22a2.98 2.98 0 0 0 2.818-2H9.182A2.98 2.98 0 0 0 12 22zM5 10v4.586l-1.707 1.707A.996.996 0 0 0 3 17v1a1 1 0 0 0 1 1h10.879L5.068 9.189C5.037 9.457 5 9.724 5 10z"></path></svg>
                                 `
            e.target.disabled = false
            removeNotifyBtn.style.display = 'grid'
            console.log(response)

          } else {
            
            e.target.disabled = false
            e.target.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; fill: <%= userReq.userColor %>;transform: msFilter"><path d="M20.345 18.931A.993.993 0 0 0 21 18v-1a.996.996 0 0 0-.293-.707L19 14.586V10c0-3.217-2.185-5.927-5.145-6.742C13.562 2.52 12.846 2 12 2s-1.562.52-1.855 1.258c-1.323.364-2.463 1.128-3.346 2.127L3.707 2.293 2.293 3.707l18 18 1.414-1.414-1.362-1.362zM12 22a2.98 2.98 0 0 0 2.818-2H9.182A2.98 2.98 0 0 0 12 22zM5 10v4.586l-1.707 1.707A.996.996 0 0 0 3 17v1a1 1 0 0 0 1 1h10.879L5.068 9.189C5.037 9.457 5 9.724 5 10z"></path></svg>
                                 `       
            console.log(response)

          }
          
        } catch (error) {
            
            e.target.disabled = false
            setTimeout(() => {
              e.target.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; fill: <%= userReq.userColor %>;transform: msFilter"><path d="M20.345 18.931A.993.993 0 0 0 21 18v-1a.996.996 0 0 0-.293-.707L19 14.586V10c0-3.217-2.185-5.927-5.145-6.742C13.562 2.52 12.846 2 12 2s-1.562.52-1.855 1.258c-1.323.364-2.463 1.128-3.346 2.127L3.707 2.293 2.293 3.707l18 18 1.414-1.414-1.362-1.362zM12 22a2.98 2.98 0 0 0 2.818-2H9.182A2.98 2.98 0 0 0 12 22zM5 10v4.586l-1.707 1.707A.996.996 0 0 0 3 17v1a1 1 0 0 0 1 1h10.879L5.068 9.189C5.037 9.457 5 9.724 5 10z"></path></svg>
                                 `
            }, 500)
            console.log(error)                     

        }
  })

  removeNotifyBtn.addEventListener('click', async (e) => {
        
        e.target.innerHTML = `${dot(userColor)}`
        e.target.disabled = true
        const payload = { recipientId: '<%= user._id %>' }
        
        try {

          const response = await socket.timeout(5000).volatile.emitWithAck('removeNotification', payload)

          if (response.success) {

             e.target.disabled = false
             e.target.style.display = 'none'
             e.target.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; fill: <%= userReq.userColor %>;transform: msFilter"><path d="m5.705 3.71-1.41-1.42C1 5.563 1 7.935 1 11h1l1-.063C3 8.009 3 6.396 5.705 3.71zm13.999-1.42-1.408 1.42C21 6.396 21 8.009 21 11l2-.063c0-3.002 0-5.374-3.296-8.647zM12 22a2.98 2.98 0 0 0 2.818-2H9.182A2.98 2.98 0 0 0 12 22zm7-7.414V10c0-3.217-2.185-5.927-5.145-6.742C13.562 2.52 12.846 2 12 2s-1.562.52-1.855 1.258C7.184 4.073 5 6.783 5 10v4.586l-1.707 1.707A.996.996 0 0 0 3 17v1a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-1a.996.996 0 0 0-.293-.707L19 14.586z"></path></svg>
                                  `
             addNotifyBtn.style.display = 'grid'
             console.log(response)

          } else {
             
             e.target.disabled = false
             e.target.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; fill: <%= userReq.userColor %>;transform: msFilter"><path d="m5.705 3.71-1.41-1.42C1 5.563 1 7.935 1 11h1l1-.063C3 8.009 3 6.396 5.705 3.71zm13.999-1.42-1.408 1.42C21 6.396 21 8.009 21 11l2-.063c0-3.002 0-5.374-3.296-8.647zM12 22a2.98 2.98 0 0 0 2.818-2H9.182A2.98 2.98 0 0 0 12 22zm7-7.414V10c0-3.217-2.185-5.927-5.145-6.742C13.562 2.52 12.846 2 12 2s-1.562.52-1.855 1.258C7.184 4.073 5 6.783 5 10v4.586l-1.707 1.707A.996.996 0 0 0 3 17v1a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-1a.996.996 0 0 0-.293-.707L19 14.586z"></path></svg>
                                  `
             console.log(response)
          }
          
        } catch (error) {

           e.target.disabled = false
           setTimeout(() => {
              e.target.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="pointer-events: none; fill: <%= userReq.userColor %>;transform: msFilter"><path d="m5.705 3.71-1.41-1.42C1 5.563 1 7.935 1 11h1l1-.063C3 8.009 3 6.396 5.705 3.71zm13.999-1.42-1.408 1.42C21 6.396 21 8.009 21 11l2-.063c0-3.002 0-5.374-3.296-8.647zM12 22a2.98 2.98 0 0 0 2.818-2H9.182A2.98 2.98 0 0 0 12 22zm7-7.414V10c0-3.217-2.185-5.927-5.145-6.742C13.562 2.52 12.846 2 12 2s-1.562.52-1.855 1.258C7.184 4.073 5 6.783 5 10v4.586l-1.707 1.707A.996.996 0 0 0 3 17v1a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-1a.996.996 0 0 0-.293-.707L19 14.586z"></path></svg>
                                  `
           }, 500)
           console.log(error)
          
        }
  })

  
  const postImages = document.querySelectorAll('.post-images')
  const expandedArticle = document.querySelector('#expanded-article')
  const expandContainer = document.querySelector('#images-expand')
  const linkToPost = document.getElementById('link-to-post')

  const modal = document.querySelector('.profile-content')

  postImages.forEach((img) => {

    
    img.addEventListener('click', (e) => {
      
       e.preventDefault();

      

       if (!history.state?.imageExpand) {

        history.pushState( { imageExpand: true}, "", "" )
       
       }
       
        
       const articleParent =  e.target.closest('article')
       const wholePost = e.target.closest('a')
       const postLink = wholePost.children[0].children[6].textContent
       const placeholderCont = articleParent.children[0]
       const imagesArray = Array.from(placeholderCont.children, child => child.textContent)
       const totalImages = imagesArray.length

       linkToPost.href = `/post/${postLink}` 
       
     
           
       imagesArray.forEach((img) => {
           const image = document.createElement('img')
           image.src = `<%= R2BASE %>/${img}`
           image.style.width = '98%'
           image.style.marginInline = '3px'
           image.style.height = 'auto'
           image.style.scrollSnapAlign = 'start'
           image.style.objectFit = 'contain'
           expandedArticle.appendChild(image)
       })
       
       
       document.getElementById('total-images').textContent = `${totalImages == 1 ? `${totalImages} Image` : `${totalImages} Images` }`
       expandContainer.style.display = 'block'
      

       })
    })
 
  
  const closeExpand = document.querySelector('#close-images-expand')

  closeExpand.addEventListener('click', () => {

      expandedArticle.innerHTML = ''
      expandContainer.style.display = 'none'
      history.back()
  })

  window.addEventListener("popstate", (event) => {
    expandContainer.style.display = 'none'
    expandedArticle.innerHTML = ''
    console.log('BackBtn: ' + event.state)
  })   

  document.querySelectorAll('.info-button').forEach((btn) => {
    
      const userReqId = '<%= userReq._id %>'
      btn.addEventListener('click', (e) => {
          
          e.preventDefault()

          // Populate modal with profile info (placeholder for now)
          const profileInfo = {
              userName: btn.children[0].textContent,
              userId: btn.children[7].textContent,
              userProfilePic: btn.children[5].getAttribute('src'),
              userHandle: btn.children[4].textContent,
              userStats: {
                  posts: btn.children[3].textContent,
                  followers: btn.children[1].textContent,
                  following: btn.children[2].textContent
              } 
          }

      
          const profileContainer = document.querySelector('#profile-info-cont')
          
          profileContainer.querySelector('img').src = profileInfo.userProfilePic  
          profileContainer.querySelector('h2').textContent = profileInfo.userName
          profileContainer.querySelector('p').textContent = profileInfo.userHandle
          profileContainer.querySelector('#following').textContent = `${profileInfo.userStats.following}`
          profileContainer.querySelector('#followers').textContent = `${profileInfo.userStats.followers}`
          profileContainer.querySelector('#posts').textContent = `${profileInfo.userStats.posts}`
          profileContainer.querySelector('#link-to-message').href = `/inbox/${profileInfo.userId}`
          profileContainer.querySelector('#link-to-profile').href = `/user/${profileInfo.userId}`
          
          if (profileInfo.userId == userReqId) {
              document.querySelector('.interact').innerHTML = `<a id="link-to-message" href="" class="stop-fetch" style="text-decoration: none; display: none; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                                 <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= user.userColor %>;transform: msFilter"><path d="M20 1.999H4c-1.103 0-2 .897-2 2v18l4-4h14c1.103 0 2-.897 2-2v-12c0-1.103-.897-2-2-2zm-6 11H7v-2h7v2zm3-4H7v-2h10v2z"></path></svg>
                                                                 <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= user.userColor %>;">Message</h2>
                                                               </a>
                                                               <a id="link-to-profile" class="stop-fetch" href="" class="stop-fetch" style="text-decoration: none; display: none; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                                 <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= user.userColor %>;transform: msFilter"><path d="M19 2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h4l3 3 3-3h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-7 3c1.727 0 3 1.272 3 3s-1.273 3-3 3c-1.726 0-3-1.272-3-3s1.274-3 3-3zM7.177 16c.558-1.723 2.496-3 4.823-3s4.266 1.277 4.823 3H7.177z"></path></svg>
                                                                 <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= user.userColor %>;">Profile</h2>
                                                               </a>
                                                               <a id="link-to-profile" class="stop-fetch" href="/user/${profileInfo.userId}" class="stop-fetch" style="text-decoration: none; display: none; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                                 <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= user.userColor %>;transform: msFilter"><path d="M19 2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h4l3 3 3-3h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-7 3c1.727 0 3 1.272 3 3s-1.273 3-3 3c-1.726 0-3-1.272-3-3s1.274-3 3-3zM7.177 16c.558-1.723 2.496-3 4.823-3s4.266 1.277 4.823 3H7.177z"></path></svg>
                                                                 <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= user.userColor %>;">Your Profile</h2>
                                                               </a>
                                                              `
          } else {
             
              document.querySelector('.interact').innerHTML = `<a id="link-to-message" href="/inbox/${profileInfo.userId}" class="stop-fetch" style="text-decoration: none; display: flex; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                                 <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= user.userColor %>;transform: msFilter"><path d="M20 1.999H4c-1.103 0-2 .897-2 2v18l4-4h14c1.103 0 2-.897 2-2v-12c0-1.103-.897-2-2-2zm-6 11H7v-2h7v2zm3-4H7v-2h10v2z"></path></svg>
                                                                 <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= user.userColor %>;">Message</h2>
                                                               </a>
                                                               <a id="link-to-profile" class="stop-fetch" href="/user/${profileInfo.userId}" class="stop-fetch" style="text-decoration: none; display: none; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                                 <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= user.userColor %>;transform: msFilter"><path d="M19 2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h4l3 3 3-3h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-7 3c1.727 0 3 1.272 3 3s-1.273 3-3 3c-1.726 0-3-1.272-3-3s1.274-3 3-3zM7.177 16c.558-1.723 2.496-3 4.823-3s4.266 1.277 4.823 3H7.177z"></path></svg>
                                                                 <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= user.userColor %>;">Profile</h2>
                                                               </a>
                                                               <a id="link-to-profile" class="stop-fetch" href="/user/${profileInfo.userId}" class="stop-fetch" style="text-decoration: none; display: none; flex-flow: column nowrap; justify-content: center; align-items: center;">
                                                                 <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= user.userColor %>;transform: msFilter"><path d="M19 2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h4l3 3 3-3h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-7 3c1.727 0 3 1.272 3 3s-1.273 3-3 3c-1.726 0-3-1.272-3-3s1.274-3 3-3zM7.177 16c.558-1.723 2.496-3 4.823-3s4.266 1.277 4.823 3H7.177z"></path></svg>
                                                                 <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= user.userColor %>;">Your Profile</h2>
                                                               </a>
                                                              `
             

          }

          document.querySelector('.overlay').style.display = 'block'
          document.getElementById('profile-wrapper').style.display = 'block'
          setTimeout(() => {
              modal.style.transition = 'top 0.3s ease-out'
              modal.style.top = '50%'
      
          }, 200)
      })

    })

  let startY = 0
  let currentY = 0
  let dragging = false



  modal.addEventListener('touchstart', (e) => {
       startY = e.touches[0].clientY
       dragging = true

       modal.style.transition = 'none'
  })

  modal.addEventListener('touchmove', (e) => {
      if(!dragging) return;
      currentY = e.touches[0].clientY
      const deltaY = currentY - startY

      if (deltaY > 0) {  // ONLY MOVE DOWNWARD
           
           modal.style.transform = `translateY(${deltaY}px)`
           // fade background
           const opacity = 0.4 - deltaY / 500
           document.querySelector('.overlay').style.background = `rgba(128, 128, 128, ${opacity})`

      }

  })
  
  modal.addEventListener('touchend', (e) => {
       dragging = false
       const deltaY = currentY - startY

       if (deltaY > 100) {
           modal.style.transition = 'top 0.3s ease-out'
           modal.style.top = '100%'
           document.querySelector('.overlay').style.background = `rgba(128, 128, 128, 0)` 
           setTimeout(() => { // reset all tripped props
               document.getElementById('profile-wrapper').style.display = 'none'
               document.querySelector('.overlay').style.display = 'none'
               document.querySelector('.overlay').style.background = `rgba(128, 128, 128, 0.4)`    
               modal.style.transform = 'translateY(0px)'
           }, 200)
            
       } else {
            modal.style.transition = 'transform 0.3s ease-out'
            modal.style.transform = `translateY(0)`
            document.querySelector('.overlay').style.background = `rgba(128, 128, 128, 0.4)`  
       }

  })

  document.querySelector('.overlay').addEventListener('click', () => {
        modal.style.transition = 'top 0.3s ease-out'
        modal.style.top = '100%'
        document.querySelector('.overlay').style.background = `rgba(128, 128, 128, 0)`
        setTimeout(() => {
            document.getElementById('profile-wrapper').style.display = 'none'
            document.querySelector('.overlay').style.display = 'none'
            document.querySelector('.overlay').style.background = `rgba(128, 128, 128, 0.4)`
            modal.style.top = '100%'
        }, 200)
    })

  const observerOptions = {
       root: null,
       rootMargin: '0px',
       threshold: 0.1
  }
  
  const videoObserver = new IntersectionObserver((entries, observer) => {

     entries.forEach(entry => {
       const container = entry.target
       const video = container.querySelector('video')
       const videoUrl = video.getAttribute('data-src')
  
         if (entry.isIntersecting) {

             if (!video.src) {
              video.src = videoUrl
             }

             video.preload = 'auto'
            //  video.play().catch(err => console.log('Video play error:', err))

         } else {
            
             video.pause()
             // don't remove src attribute from video
             video.preload = 'none'
                                            // Forces browser to flush the buffer and release memory
         }
     })
}, observerOptions)

  document.querySelectorAll('.glass').forEach(container => {
     videoObserver.observe(container)
  })





</script>     

 
