    <style>
/* ── FOUNDATION ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:#050508;color:#ede8e0;font-family:'Plus Jakarta Sans',sans-serif;-webkit-font-smoothing:antialiased}
#app{height:100%;position:relative;overflow:hidden}
canvas{position:fixed;inset:0;z-index:0;pointer-events:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,textarea{font-family:inherit;border:none;outline:none;background:none;color:inherit}
::-webkit-scrollbar{width:0;height:0}

/* ── TYPE ── */
.fd{font-family:'Playfair Display',serif}
.fs{font-family:'DM Serif Display',serif}

/* ── LAYOUT ── */
.view{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;overflow:hidden;animation:viewIn .42s cubic-bezier(.22,.61,.36,1) both}
.scroll{overflow-y:auto;-webkit-overflow-scrolling:touch}
.glass{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}

/* ── INTERACTIONS ── */
.tap{cursor:pointer;transition:transform .12s ease,opacity .12s ease;user-select:none;-webkit-user-select:none}
.tap:active{transform:scale(.91)!important;opacity:.72!important}

/* ── ANIMATIONS ── */
@keyframes viewIn      {from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes emerge      {from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn      {from{opacity:0}to{opacity:1}}
@keyframes orbIn       {from{opacity:0;transform:scale(.55)}to{opacity:1;transform:scale(1)}}
@keyframes msgPop      {from{opacity:0;transform:translateY(6px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes throb       {0%,100%{opacity:.42}50%{opacity:1}}
@keyframes drift       {0%,100%{transform:translateY(0) rotate(0deg)}40%{transform:translateY(-10px) rotate(.6deg)}75%{transform:translateY(4px) rotate(-.3deg)}}
@keyframes speak       {0%,100%{transform:scale(1.03)}50%{transform:scale(1.15)}}
@keyframes xpFill      {from{width:0%}}
@keyframes dotBlink    {0%,80%,100%{transform:scale(0);opacity:.4}40%{transform:scale(1);opacity:1}}
@keyframes effBurst    {0%{transform:scale(1);opacity:1}60%{transform:scale(1.6);opacity:.5}100%{transform:scale(2.4);opacity:0}}
@keyframes storyPulse  {0%,100%{box-shadow:0 0 0 0 var(--sc)}50%{box-shadow:0 0 0 4px var(--sc)}}
@keyframes heartbeat   {0%,100%{transform:scale(1)}14%{transform:scale(1.1)}28%{transform:scale(1)}42%{transform:scale(1.06)}}
@keyframes shimmer     {0%{background-position:-200% center}100%{background-position:200% center}}
</style>
</head>
