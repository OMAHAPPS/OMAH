    <div class="view" id="view-to-post" style="display: none; background:rgba(5,5,8)">

      <div style="padding: 13px 16px;border-bottom:1px solid rgba(255,255,255,.05); display: flex; align-items:center; gap:10px; flex-shrink:0">

          <button onclick="back()" class="back" style="padding: 7px 14px; border-radius: 10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);font-size:12px;color:rgba(237,232,224,.6)">
            ✕ Cancel
          </button>
          <div class="fd" style="flex:1;font-size:16px;font-weight:700;color:rgba(237,232,224,.8)">
            Write
          </div>
      
          <form id="post-form" action="/post" method="post">
            <input id="userid" name="userid" value="<%= user._id %>" type="text" style="display: none;">
            <input id="userrealm" name="userrealm" value="<%= user.userRealm %>" type="text" style="display: none;">
            <input id="post-input-elem" name="poststring" type="text" style="display: none;">
            <input id="post-image-input" name="imagesrc" type="text" style="display: none;" value="none" />
             
          <button type="submit" id="post-submit-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> class="tap" style="display: none; padding: 8px 20px;border-radius:12px;font-size:12px;font-weight:600;background: <%= user.userColor %>18;border: 1px solid <%= user.userColor %>52;color: <%= user.userColor %>;">Share</button>
          </form>
      </div>
      <div style="height: 78%; padding: 18px 16px; flex:1; display:flex; flex-flow: column nowrap; gap: 14px;">
        
              <div style="height: 8%; padding: 10px; display: flex; align-items: center; gap:10px;">
                 <div>
                    <div style="font-size:13px;font-weight:600;color:rgba(237,232,224,.8)">
                       <%= user.userName %>
                    </div>
                    <div style="font-size:10px;color:rgba(237,232,224,.3)">
                      writing to The <%= user.userRealm %>
                    </div>
                 </div>
                 <div class="progress-wrapper" style="height: 100%; display: none; flex-flow: column nowrap; align-items: center; justify-content: center; flex-grow: 1;">
                  <h3 id="upload-status" style="font-size: 15px; color: white; width: 90%; text-align: start;">Uploading Files...</h3>     
                  <div class="prog-wrapper" style="margin-top: 5px; width: 90%; display: flex; align-items: center; justify-content: center;">
                    <progress id="overallProgress" style="width: 100%; border-radius: 50%; background-color: #1ed760;" value="75" max="100"></progress>
                    <p class="progress-text" style="color: white; margin-left: 4px; font-size: .75rem;"></p>
                  </div>
                 </div>
              </div>
      
              <div class="post-box" style="height: 88%; display: flex; flex-flow: column nowrap;">
 
                  <textarea id="post-body" placeholder="Add Caption..." maxlength="500" style="padding: 16px; border-radius: 18px 18px 0 0; font-size: 15px; line-height: 1.72; color:rgba(237,232,224,.82); background:rgba(255,255,255,.02); border: 2px solid rgba(255,255,255,.07); flex-grow: 1;"></textarea>
                
                   <!--! ///// IMAGE TO BE RENDERED IN JS AFTER MULTER UPLOAD ////  -->
                  <article id="image-article" style="width: clamp(350px, 100%, 600px); height: 60%; display: none; overflow-x: scroll; overflow-y: hidden; border-radius: 0 0 18px 18px; scroll-snap-type: inline mandatory;">
                            
                            
                  </article>

        
              </div>   

              <div style="text-align:right;font-size:10px;color:rgba(237,232,224,.2)">🔒 Stays within The <%= user.userRealm %></div>
      </div>
  </div>

  <section id="profile-wrapper" style="display: none; position: absolute; top: 0; height: 100%; width: 100%; z-index: 4; gap: 12px; overflow-y: scroll; overflow-x: hidden;">

        <div class="overlay" style="display: none; position: absolute; inset: 0; height: 100%; width: 100%; z-index: 3; background-color: rgba(128, 128, 128, 0.4);"></div>

        <nav class="profile-content" style=" position: absolute; top: 100%; z-index: 4; border-radius: 50px 50px 0 0; width: 100%; height: 50%; background-color: #050508; touch-action: none; will-change: transform;">

                <div class="scroll-icon" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="width: 40px; height: 4px; background-color: <%= user.userColor %>; border-radius: 2px; position: absolute; top: 20px; left: 50%; transform: translateX(-50%);"></div>    

                <div id="profile-info-cont" style="margin-top: 20px; display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 24px 16px;">


                      <img src="/uploads/mwatiJS-1780147920696.jpeg" alt="" width="100" height="100" style="border-radius: 50%; object-fit: cover;" />

                   


                    <h2 style="font-size: 18px; font-weight: 700; color: rgba(237,232,224,.85);"></h2>

                    <p style="font-size: 16px; color: rgba(237,232,224,.45);"></p>

                    <div class="follow-wrapper" style="display: flex; justify-content: space-around; align-items: center; width: 100%; height: 40px;">
                         
                      <div class="following-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 5px;">
                        <p id="following" style="color: white; font-size: 16px; font-weight: bold;"></p>
                        <span style="color: rgba(237,232,224,.45);">Following</span>
                      </div>
                      <div class="followers-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 5px;">
                        <p id="followers" style="color: white; font-size: 16px; font-weight: bold;"></p>
                        <span style="color: rgba(237,232,224,.45);">Followers</span>

                      </div>
                      <div class="posts-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 5px;">
                        <p id="posts" style="color: white; font-size: 16px; font-weight: bold;"></p>
                        <span style="color: rgba(237,232,224,.45);">Posts</span>
                      </div>
                        
                    </div>

                    <div class="interact" style="width: 100%; background-color: transparent; margin-top: 10px; display: flex; justify-content: space-evenly; align-items: center;">

                      <a href="/inbox" class="stop-fetch" style="text-decoration: none; display: flex; flex-flow: column nowrap; justify-content: center; align-items: center;">
                           <svg <% /* eslint-disable-next-line css-propertyvalueexpected */ %> xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" style="fill: <%= user.userColor %>;transform: msFilter"><path d="M20 1.999H4c-1.103 0-2 .897-2 2v18l4-4h14c1.103 0 2-.897 2-2v-12c0-1.103-.897-2-2-2zm-6 11H7v-2h7v2zm3-4H7v-2h10v2z"></path></svg>
                           <h3 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: .9rem; color: <%= user.userColor %>;">Message</h2>
                      </a>
                      <div class="follow-btn" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="display: grid; place-content: center; padding: 15px; height: 40px; width: fit-content; border-radius: 20px; border: 1px solid <%= user.userColor %>; background-color: transparent;">
                        <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="color: <%= user.userColor %>; font-size: .9rem;">Following</h4>
                      </div>

                    </div>


                </div>  
        </nav>
        
    </section>

    <div id="images-expand" style="display: none; background-color: black; position: absolute; top: 0; height: 100%; width: 100%; z-index: 100; overflow-x: scroll;">

            <div id="link-holders" style="width: 100%; height: 15%; display: flex; align-items: center; justify-content: space-between; padding: 20px;">

              <button id="close-images-expand" style="border: 1px solid rgba(237,232,224,.2); height: 40px; width: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <ion-icon name="arrow-back-outline" style="color: white; font-size: 1.2rem;"></ion-icon>
              </button>

               <a id="link-to-post" href="" class="stop-fetch" <% /* eslint-disable-next-line css-propertyvalueexpected */ %>  style="text-decoration: none; display: grid; place-content: center; padding: 15px; height: 40px; width: fit-content; border-radius: 20px; border: 1px solid <%= user.userColor %>; background-color: transparent;">
                  <h4 <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="color: <%= user.userColor %>; font-size: .9rem;">View Post</h4>
               </a> 

            </div>
            <article id="expanded-article" style="width: 100%; height: 85%; display: flex; gap:5px; align-items: center; justify-content: flex-start; overflow-x: auto; overflow-y: hidden; scroll-snap-type: inline mandatory;">
               
               
            </article>
    </div>  

 
<script src="homeScript.js"></script>
</body>
</html>
