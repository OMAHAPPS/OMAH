                                  <% post.images.map((image, key) => { %>
                                    <p id="<%= key %>" ><%= image %></p>
                                  <% }) %>
                            </div> 
        
                            <% post.images.map((image) => { %>
        
                              <img class="post-images" src="<%= R2BASE %>/<%= image %>" alt="N" style="width: auto; height: 100%; object-fit: contain; margin-right: 3px;" />
        
                            <% }) %>
         
                          </article>

                        <% } %>



                 
                   <!-- ! Likes and counts container -->

              <div style="display:flex;align-items:center; justify-content: space-around; gap:15px;border-top:1px solid rgba(255,255,255,.05);padding-top:10px; margin-top: 5px;">
                     <div class="likes-cont" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="heart-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %>  style="font-size: 16px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                         <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %>   style="font-size: 13px; color: <%= user.userColor %>; font-weight: bold; margin-left: 3px;"><%= post.likes %></span>
                     </div>   
                     <div class="reply-button" style="display: flex; align-items: center; justify-content: center;">
                       <ion-icon name="chatbubble-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %>  style="font-size: 16px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                       <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 13px; color: <%= user.userColor %>; font-weight: bold; margin-left: 3px;"><%= post.replies %></span>
                     </div>
                     <div class="interactions" style="display: flex; align-items: center; justify-content: center;">
                         <ion-icon name="barcode-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 16px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                         <span <% /* eslint-disable-next-line css-propertyvalueexpected */ %> style="font-size: 13px; color: <%= user.userColor %>; font-weight: bold; margin-left: 3px;"><%= post.interactions %></span>
                     </div> 

                     <ion-icon name="share-social-outline" <% /* eslint-disable-next-line css-propertyvalueexpected */ %>  style="font-size: 20px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                     <ion-icon name="repeat" <% /* eslint-disable-next-line css-propertyvalueexpected */ %>  style="font-size: 20px; font-weight: bold; color: <%= user.userColor %>;"></ion-icon>
                   
              </div>
         </div> 
                
                <% }) %>
                        
              <% } %>
                
            </section>
            
