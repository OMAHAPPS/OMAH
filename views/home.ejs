           if (deltaY > 0) {
              modal.style.transform = `translateY(${deltaY}px)`

              // fade background
              const opacity = 0.4 - deltaY / 500
              document.querySelector('.overlay').style.background = `rgba(128, 128, 128, ${opacity})`
            }
