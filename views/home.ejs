       expandContainer.style.display = 'block'
        

       } else if (likeActions) {
        e.preventDefault()
        const currentActiveState = likeActions.dataset.liked === 'true'
        const likeIcon = likeActions.querySelector('.like')
        const unlikeIcon = likeActions.querySelector('.unlike')
        const h3Span = likeActions.querySelector('.like-h3')
        const postId = likeActions.querySelector('.postId-span').textContent
        
        const newLikedState = !currentActiveState

        likeActions.dataset.liked = (newLikedState).toString()

        if (newLikedState) {

             likeIcon.style.display = 'block'
             likeIcon.style.scale = '1.2'
             unlikeIcon.style.display = 'none'

        } else {
 
             likeIcon.style.display = 'none'
             unlikeIcon.style.display = 'block'
             unlikeIcon.style.scale = '1.2'

        }

        clearTimeout(debounceTimer)

        const updateDB = async (postId, btn) => {

                         const currentDataSet = btn.dataset.liked
                         const payload = { postId: postId, dataset: currentDataSet }


                     try {
                      
                       const response = await socket.timeout(5000).volatile.emitWithAck("update-likes", payload)
           
                       if (response.success) {
                         // update Success Instance
                       if (response.UIStatus == 'like') {
  
                          h3Span.textContent = response.newLikesCount
                          likeIcon.style.display = 'block'
                          likeIcon.style.scale = '1'
                          unlikeIcon.style.display = 'none'

                        } else {
                          h3Span.textContent = response.newLikesCount
                          likeIcon.style.display = 'none'
                          unlikeIcon.style.display = 'block'
                          unlikeIcon.style.scale = '1'
          
      
                        }

                        } else {
                         // failure instance
                          likeIcon.style.display = 'none'
                          unlikeIcon.style.display = 'block'
                          unlikeIcon.style.scale = '1'
                          console.log('Likes did not comeThrough')

                        }

                     } catch (error) {

                          likeIcon.style.display = 'none'
                          unlikeIcon.style.display = 'block'
                          unlikeIcon.style.scale = '1'
                          errorMessage.textContent = 'Connection Failure'
                          setTimeout(() => {
                           errorMessage.textContent = ''
                          }, 1500)
                      
                     }    
                 } 

                 debounceTimer = setTimeout(() => {
      
                    updateDB(postId, likeActions)
     
                  }, 500)


       }       
 })



