function createTimeElem (timestamp) {
    
      const diff = new Date() - new Date(timestamp)
      const daysPast = Math.floor( (diff / 86400000) )
      const hoursPast = Math.floor( (diff / 3600000) )
      const minutesPast = Math.floor( (diff / 60000) ) 

       if (daysPast > 0) {

         return `<div style="pointer-events: none; font-size:12px;color: rgba(237, 232, 224, .65);margin-top:2px;">${daysPast}d</div>`

       } else if (hoursPast > 0) { 

        return  `<div style="pointer-events: none; font-size:12px;color: rgba(237,232,224,.65);margin-top: 2px;">${hoursPast}h</div>`

       } else if (minutesPast > 0) { 

        return  `<div style="pointer-events: none; font-size:12px;color: rgba(237,232,224,.65);margin-top:2px;">${minutesPast}m</div>`

       } else if (minutesPast == 0) { 

        return `<div style="pointer-events: none; font-size:12px;color: rgba(237,232,224,.65);margin-top:2px;">Just now</div>`

       } 


}

