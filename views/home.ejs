                       if (response.UIStatus == 'like') {
  
                          h3Span.textContent = response.newLikesCount
                          likeIcon.style.display = 'block'
                          likeIcon.style.scale = '1'
                          unlikeIcon.style.display = 'none'

                        } else {
                          h3Span.textContent = response.newLikesCount
                          likeIcon.style.display = 'none'
                          unlikeIcon.style.display = 'block'
                          unlikeIcon.style.scale = '1'
          
      
                        }

                        } else {
                         // failure instance
                          likeIcon.style.display = 'none'
                          unlikeIcon.style.display = 'block'
                          unlikeIcon.style.scale = '1'
                          console.log('Likes did not comeThrough')

                        }

                     } catch (error) {

                          likeIcon.style.display = 'none'
                          unlikeIcon.style.display = 'block'
                          unlikeIcon.style.scale = '1'
                          errorMessage.textContent = 'Connection Failure'
                          setTimeout(() => {
                           errorMessage.textContent = ''
                          }, 1500)
                      
                     }    
                 } 

                 debounceTimer = setTimeout(() => {
      
                    updateDB(postId, likeActions)
     
                  }, 500)


       }       
 })





