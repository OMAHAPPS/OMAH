      if ('serviceWorker' in navigator && 'PushManager' in window) {


           try {
              // Register the service worker file
              const registration = await navigator.serviceWorker.register('/sw.js')
              console.log('Service Worker registered safely.')

              // Request native browser permission to show notifications
              const permission = await Notification.requestPermission()

              if (permission === 'granted') {
        
                // Fetch the public VAPID key from backend
                const keyRes = await fetch('/api/vapid-public-key', {
                      method: 'GET',
                      headers: {
                        "Content-Type": "application/json"
                      }
                })
                const data = await keyRes.json()
                const publicKey = data.publicKey

                // Convert key format to handle security handshake boundaries
                const convertedPublicKey = urlBase64ToUint8Array(publicKey)

                // Tell browser push manager to generate a token endpoint
                const subscription = await registration.pushManager.subscribe({
                   userVisibleOnly: true,
                   applicationServerKey: convertedPublicKey
                })

                // Pass subscription details to backend database map
                await fetch('/api/notifications/subscribe', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ userId: currentUserId, subscription: subscription })
                            })
                }

            } catch (err) {

               console.error('Push subscription pipeline setup failed:', err);
            }
         }



