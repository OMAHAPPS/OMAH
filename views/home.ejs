const interactionsScrollThreshold = 10; // Adjust this value as needed

interactionsContainer.addEventListener('scroll', () => {
  const scrollTop = interactionsContainer.scrollTop
  const scrollDistance = Math.abs(scrollTop - lastInteractionsScrollTopPosition)

  if (scrollTop === 0) {

    // Scrolling up
          forYouTabsContainer.style.height = '8%'
          forYouTabsContainer.style.opacity = '1'
          mainForYouContainer.style.height = '92%'

  } else if (scrollDistance > interactionsScrollThreshold) {
         
       if (scrollTop > lastInteractionsScrollTopPosition) {
          // Scrolling down
          forYouTabsContainer.style.opacity = '0'
          forYouTabsContainer.style.height = '0'
          mainForYouContainer.style.height = '100%'
       } else {
          // Scrolling up
          forYouTabsContainer.style.height = '8%'
          forYouTabsContainer.style.opacity = '1'
          mainForYouContainer.style.height = '92%'
       }
      }  
      lastInteractionsScrollTopPosition = scrollTop <= 0 ? 0 : scrollTop
    })

