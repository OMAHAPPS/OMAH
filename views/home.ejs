})

cancelUploadBtn.addEventListener('click', (e) => {
     
     e.preventDefault()
     submitActionsCont.style.display = 'none'
     postPlaceholder.textContent = 'Write something real...'
     labelFileInput.style.display = 'block'
     submitUploadBtn.disabled = false
     submitUploadBtn.style.backgroundColor = '#1ed760'
     submitUploadBtn.textContent = 'Upload'
     inputFile.value = ''
})

 submitUploadBtn.addEventListener('click', (e) => {

   e.preventDefault()
   
   submitUploadBtn.disabled = true
   submitUploadBtn.style.backgroundColor = '#121212'
   submitUploadBtn.textContent = 'Uploading...'

     
     if (inputFile.files.length === 0) {
          errorMessage.textContent = 'No Image Selected...'
          setInterval(() => {
            errorMessage.textContent = ''
          }, 2000)
          submitActionsCont.style.display = 'none'
          labelFileInput.style.display = 'block'
          submitUploadBtn.disabled = false
          submitUploadBtn.style.backgroundColor = '#1ed760'
          submitUploadBtn.textContent = 'Upload'
          return;
     } else {
       const selectedFile = inputFile.files[0]

        if (!selectedFile.type.startsWith('image/')) {
            errorMessage.textContent = 'Selected file is not an image...'
            setInterval(() => {
              errorMessage.textContent = ''
            }, 2000)
            submitActionsCont.style.display = 'none'
            labelFileInput.style.display = 'block'
            submitUploadBtn.disabled = false
            submitUploadBtn.style.backgroundColor = '#1ed760'
            submitUploadBtn.textContent = 'Upload'
            return;
        } else {

          const formData = new FormData()
          
          formData.append('image', selectedFile)
          
          fetch('/post/upload', {
            method: 'POST',
            body: formData
          }).then((response) => {
            if (response.ok) {

                      return response.json()
                    } else {
                      errorMessage.textContent = 'Uploading currently unavailable...'
                      setInterval(() => {
                        errorMessage.textContent = ''
                      }, 2000)
                      throw new Error('Network response was not ok')
                      submitUploadBtn.disabled = false
                      submitUploadBtn.style.backgroundColor = '#1ed760'
                      submitUploadBtn.textContent = 'Upload'
                    }
                  }).then((data) => {
                    
                    // console.log(data)
                    
               document.getElementById('filepath').textContent = data.filename
               const image = `<img src=/uploads/${data.filename} alt="" style="width: 100%; height: 100%;" />`
               imagePostInput.value = data.filename

                imageArticle.innerHTML = image
                imageArticle.style.display = 'block'
                viewToPostCont.style.display = 'block'
                sharePostBtn.style.display = 'none'
                
          
            }).catch((error) => {
                errorMessage.textContent = 'Error uploading image. Please try again.'
                setInterval(() => {
                  errorMessage.textContent = ''
                }, 2000)
                 submitActionsCont.style.display = 'none'
                 labelFileInput.style.display = 'block'
                 submitUploadBtn.disabled = false
                 submitUploadBtn.style.backgroundColor = '#1ed760'
                 submitUploadBtn.textContent = 'Upload'
          })





        }


     }
 })




