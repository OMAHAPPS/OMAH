      <path d="M${cx-s*.18} ${cy-s*.22} L${cx-s*.1} ${cy-s*.36} L${cx} ${cy-s*.25} L${cx+s*.1} ${cy-s*.4} L${cx+s*.18} ${cy-s*.22}"
