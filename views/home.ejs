    feedsBtn.style.borderBottom = '2px solid transparent'
    postScrollContainer.style.left = '-200%'
    messagesScrollContainer.style.left = '-100%'
    groupsScrollContainer.style.left = '0'
    sharePostBtn.style.display = 'none'

