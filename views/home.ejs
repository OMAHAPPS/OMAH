      <path d="M${cx-s*.17} ${cy-s*.15} Q${cx-s*.22} ${cy+s*.1} ${cx-s*.2} ${cy+s*.35}" stroke="${c}" stroke-width="3" fill="none" opacity=".45" stroke-linecap="round"/>
